const FAQPage = () => {
  const [open, setOpen] = useState(null);
  const faqs = [
    ["What payment methods do you accept?", "We accept all major credit/debit cards, PayPal, and crypto payments via our secure gateway."],
    ["How long does shipping take?", "Standard shipping: 5-7 days. Express: 2-3 days. Free shipping on orders over $100."],
    ["What is your return policy?", "30-day hassle-free returns on all items. Just contact support and we'll arrange pickup."],
    ["Are products covered under warranty?", "All products come with a minimum 1-year manufacturer's warranty. We offer extended 2-year warranty."],
    ["Do you ship internationally?", "Yes! We ship to 50+ countries worldwide. International rates apply."],
    ["Can I track my order?", "Absolutely. Visit our Track Order page with your order ID to get real-time updates."],
  ];
  return (
    <div className="page-fade">
      <div className="page-hero"><h1 className="page-hero-title">FAQ</h1></div>
      <div className="container py-5" style={{ maxWidth: 700 }}>
        {faqs.map(([q, a], i) => (
          <div key={i} style={{ background: "var(--card)", border: "1px solid var(--border)", borderRadius: 8, marginBottom: 12, overflow: "hidden" }}>
            <button onClick={() => setOpen(open === i ? null : i)} style={{ width: "100%", padding: "16px 20px", background: "none", border: "none", color: "var(--text)", fontFamily: "Rajdhani", fontWeight: 600, fontSize: "1rem", display: "flex", justifyContent: "space-between", cursor: "pointer" }}>
              {q} <span style={{ color: "var(--cyan)" }}>{open === i ? "−" : "+"}</span>
            </button>
            {open === i && <div style={{ padding: "0 20px 16px", color: "var(--muted)", fontSize: "0.9rem", lineHeight: 1.7 }}>{a}</div>}
          </div>
        ))}
      </div>
    </div>
  );
};

const TrackPage = () => {
  const [id, setId] = useState("");
  const [result, setResult] = useState(null);
  const track = async () => {
    if (!id.trim()) return;
    try {
      const ref = doc(db, "orders", id.trim());
      const snap = await getDoc(ref);
      setResult(snap.exists() ? { found: true, ...snap.data() } : { found: false });
    } catch { setResult({ found: false }); }
  };
  return (
    <div className="page-fade">
      <div className="page-hero"><h1 className="page-hero-title">TRACK ORDER</h1></div>
      <div className="container py-5" style={{ maxWidth: 500 }}>
        <div className="auth-card" style={{ maxWidth: "100%" }}>
          <div className="filter-title">ENTER ORDER ID</div>
          <div className="cyber-form-group">
            <input className="cyber-input" placeholder="e.g. abc123def456..." value={id} onChange={e => setId(e.target.value)} />
          </div>
          <button className="btn-primary-cyber" style={{ width: "100%" }} onClick={track}>TRACK ORDER</button>
          {result && (
            <div style={{ marginTop: 20 }}>
              {result.found ? (
                <div className="cyber-alert">
                  <div>Status: <span className={`status-badge status-${result.status}`}>{result.status?.toUpperCase()}</span></div>
                  <div style={{ marginTop: 8, color: "var(--muted)", fontSize: "0.85rem" }}>Total: ${result.total?.toFixed(2)}</div>
                </div>
              ) : <div className="cyber-alert cyber-alert-error">Order not found.</div>}
            </div>
          )}
        </div>
      </div>
    </div>
  );
};

// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App() {
  const [page, setPage] = useState({ name: "home" });
  const [cart, setCart] = useState([]);
  const [wishlist, setWishlist] = useState([]);
  const [user, setUser] = useState(null);
  const [toasts, setToasts] = useState([]);
  const [searchQuery, setSearchQuery] = useState("");

  useEffect(() => {
    const unsub = onAuthStateChanged(auth, u => setUser(u));
    return unsub;
  }, []);

  const showToast = (msg) => {
    const id = Date.now();
    setToasts(t => [...t, { id, msg }]);
    setTimeout(() => setToasts(t => t.filter(x => x.id !== id)), 3000);
  };

  const addToCart = (product) => {
    setCart(c => {
      const existing = c.find(i => i.id === product.id);
      if (existing) return c.map(i => i.id === product.id ? { ...i, qty: i.qty + 1 } : i);
      return [...c, { ...product, qty: 1 }];
    });
    showToast(`${product.name.slice(0, 25)}... added to cart ✦`);
  };

  const addToWishlist = (product) => {
    setWishlist(w => w.find(i => i.id === product.id) ? w : [...w, product]);
    showToast("Added to wishlist ♡");
  };

  const renderPage = () => {
    const p = page.name;
    if (p === "home") return <HomePage setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />;
    if (p === "shop") return <ShopPage setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} initialCategory={page.category} />;
    if (p === "product") return <ProductDetailPage productId={page.id} setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />;
    if (p === "search") return <SearchPage query={searchQuery} setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />;
    if (p === "deals") return <DealsPage setPage={setPage} addToCart={addToCart} />;
    if (p === "cart") return <CartPage cart={cart} setCart={setCart} setPage={setPage} />;
    if (p === "checkout") return <CheckoutPage cart={cart} setCart={setCart} setPage={setPage} user={user} showToast={showToast} />;
    if (p === "confirmation") return <ConfirmationPage orderId={page.orderId} setPage={setPage} />;
    if (p === "login") return <LoginPage setPage={setPage} setUser={setUser} showToast={showToast} />;
    if (p === "account") return <AccountPage user={user} setUser={setUser} setPage={setPage} wishlist={wishlist} showToast={showToast} />;
    if (p === "about") return <AboutPage />;
    if (p === "contact") return <ContactPage />;
    if (p === "faq") return <FAQPage />;
    if (p === "trackorder") return <TrackPage />;
    if (p === "returns") return (
      <div className="page-fade">
        <div className="page-hero"><h1 className="page-hero-title">RETURNS POLICY</h1></div>
        <div className="container py-5" style={{ maxWidth: 700 }}>
          <div style={{ color: "var(--muted)", lineHeight: 2 }}>
            <h3 style={{ fontFamily: "Orbitron", color: "var(--cyan)", fontSize: "1rem", marginBottom: 16 }}>30-DAY RETURN POLICY</h3>
            <p>We offer a full 30-day return policy on all products. Items must be in their original condition and packaging. Contact support@shopshopie.com to initiate a return. Refunds are processed within 5-7 business days.</p>
          </div>
        </div>
      </div>
    );
    return <HomePage setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />;
  };

  return (
    <>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
      <GlobalStyles />
      <Navbar page={page} setPage={setPage} cart={cart} user={user} searchQuery={searchQuery} setSearchQuery={setSearchQuery} />
      <main style={{ minHeight: "70vh" }}>{renderPage()}</main>
      <Footer setPage={setPage} />
      <Toast toasts={toasts} />
    </>
  );
}