  // Fetch all images from all folders
  const imageMap = {}; // e.g. { "electronics-4-1": "electronics-4-1_yqiw61" }

  for (const folder of FOLDERS) {
    process.stdout.write(`  Fetching ${folder}... `);
    try {
      const resources = await fetchFolder(folder);
      console.log(`${resources.length} images found`);
      for (const r of resources) {
        // public_id looks like: megastore/electronics/electronics-4-1_yqiw61
        const parts  = r.public_id.split("/");
        const fname  = parts[parts.length - 1]; // electronics-4-1_yqiw61
        // extract base key: electronics-4-1
        const match  = fname.match(/^(.+?-\d+-\d+)/);
        if (match) {
          const key = match[1]; // e.g. electronics-4-1
          imageMap[key] = fname;
          // build the final URL
          const url = `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/${TRANSFORM}/${fname}.jpg`;
          imageMap[key + "__url"] = url;
        }
      }
    } catch(e) {
      console.log(`ERROR: ${e.message}`);
    }
  }

  console.log(`\n✅ Total images found: ${Object.keys(imageMap).filter(k => !k.endsWith("__url")).length}`);

  // Show what we found
  console.log("\n📋 Image URL Map:");
  for (const [key, fname] of Object.entries(imageMap)) {
    if (!key.endsWith("__url")) {
      console.log(`   ${key} → ${fname}`);
    }
  }

  // Now build the replacement map for App.js
  // Map product IDs → correct image1 URL
  const productUrls = {};
  for (const [productId, baseKey] of Object.entries(PRODUCT_MAP)) {
    // Try image 1 first
    const key1 = `${baseKey}-1`;
    if (imageMap[key1 + "__url"]) {
      productUrls[productId] = imageMap[key1 + "__url"];
    } else {
      console.log(`   ⚠️  No image found for product ${productId} (looking for ${key1})`);
    }
  }

  // Read App.js
  if (!fs.existsSync(APP_JS_PATH)) {
    console.log(`\n❌ ERROR: App.js not found at ${APP_JS_PATH}`);
    console.log("   Make sure you run this script from your React project root folder");
    process.exit(1);
  }

  let appJs = fs.readFileSync(APP_JS_PATH, "utf8");

  // Replace all cloudUrl() calls with the correct URLs
  let replaced = 0;
  for (const [productId, url] of Object.entries(productUrls)) {
    // Match image1:cloudUrl("anything") and replace with correct URL
    const regex = new RegExp(`(id:"${productId}"[^}]*?image1:)cloudUrl\\("[^"]*"\\)`, "s");
    if (regex.test(appJs)) {
      appJs = appJs.replace(regex, `$1"${url}"`);
      replaced++;
    }
  }

  console.log(`\n🔧 Updated ${replaced} product image URLs in App.js`);

  // Backup original
  fs.writeFileSync(APP_JS_PATH + ".backup", fs.readFileSync(APP_JS_PATH));
  console.log(`📦 Backup saved: App.js.backup`);

  // Write updated file
  fs.writeFileSync(APP_JS_PATH, appJs);
  console.log(`✅ App.js updated successfully!`);
  console.log("\n🎉 Done! Restart your React app to see the images.");
}

main().catch(e => {
