// ─── SHOP PAGE ────────────────────────────────────────────────────────────────
const ShopPage = ({ setPage, addToCart, addToWishlist, initialCategory }) => {
  const [activeCategory, setActiveCategory] = useState(initialCategory || "all");
  const [sortBy, setSortBy] = useState("default");
  const [priceRange, setPriceRange] = useState("all");

  let filtered = activeCategory === "all" ? PRODUCTS : PRODUCTS.filter(p => p.category === activeCategory);

  if (priceRange === "under100") filtered = filtered.filter(p => p.price < 100);
  else if (priceRange === "100-300") filtered = filtered.filter(p => p.price >= 100 && p.price <= 300);
  else if (priceRange === "over300") filtered = filtered.filter(p => p.price > 300);

  if (sortBy === "price-asc") filtered = [...filtered].sort((a, b) => a.price - b.price);
  else if (sortBy === "price-desc") filtered = [...filtered].sort((a, b) => b.price - a.price);
  else if (sortBy === "rating") filtered = [...filtered].sort((a, b) => b.rating - a.rating);

  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">⬡ SHOP</h1>
        <p className="page-hero-sub">Find your perfect peripheral</p>
      </div>
      <div className="container py-5">
        <div className="row g-4">
          {/* Sidebar */}
          <div className="col-12 col-md-3">
            <div className="filter-sidebar">
              <div className="filter-title">⬡ FILTERS</div>

              <div className="filter-group">
                <div className="filter-group-label">CATEGORY</div>
                <div className="filter-check" onClick={() => setActiveCategory("all")} style={{ cursor: "pointer" }}>
                  <input type="radio" checked={activeCategory === "all"} readOnly /> All Products
                </div>
                {CATEGORIES.map(c => (
                  <div key={c.id} className="filter-check" onClick={() => setActiveCategory(c.id)} style={{ cursor: "pointer" }}>
                    <input type="radio" checked={activeCategory === c.id} readOnly />
                    {c.icon} {c.label}
                  </div>
                ))}
              </div>

              <div className="filter-group">
                <div className="filter-group-label">PRICE RANGE</div>
                {[["all", "All Prices"], ["under100", "Under $100"], ["100-300", "$100 – $300"], ["over300", "Over $300"]].map(([v, l]) => (
                  <div key={v} className="filter-check" onClick={() => setPriceRange(v)}>
                    <input type="radio" checked={priceRange === v} readOnly /> {l}
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Products Grid */}
          <div className="col-12 col-md-9">
            <div className="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
              <span style={{ color: "var(--muted)", fontSize: "0.9rem" }}>
                {filtered.length} products found
              </span>
              <select className="cyber-select" style={{ width: "auto" }} value={sortBy} onChange={e => setSortBy(e.target.value)}>
                <option value="default">Default Sort</option>
                <option value="price-asc">Price: Low to High</option>
                <option value="price-desc">Price: High to Low</option>
                <option value="rating">Top Rated</option>
              </select>
            </div>
            <div className="row g-4">
              {filtered.map(p => (
                <div key={p.id} className="col-12 col-sm-6 col-lg-4">
                  <ProductCard product={p} setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />
                </div>
              ))}
            </div>
            {filtered.length === 0 && (
              <div className="text-center py-5">
                <div style={{ fontSize: "3rem", marginBottom: 16 }}>⬡</div>
                <p style={{ color: "var(--muted)" }}>No products found</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
};

