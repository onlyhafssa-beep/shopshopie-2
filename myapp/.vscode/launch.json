);

// ─── LOGIN PAGE ───────────────────────────────────────────────────────────────
const LoginPage = ({ setPage, setUser, showToast }) => {
  const [mode, setMode] = useState("login");
  const [form, setForm] = useState({ email: "", password: "", name: "" });
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const handle = async () => {
    setLoading(true); setError("");
    try {
      if (mode === "login") {
        const cred = await signInWithEmailAndPassword(auth, form.email, form.password);
        setUser(cred.user);
        showToast("Welcome back! ✦");
        setPage({ name: "account" });
      } else {
        const cred = await createUserWithEmailAndPassword(auth, form.email, form.password);
        await addDoc(collection(db, "users"), { uid: cred.user.uid, email: form.email, name: form.name, createdAt: serverTimestamp() });
        setUser(cred.user);
        showToast("Account created! ✦");
        setPage({ name: "account" });
      }
    } catch (e) {
      setError(e.message.replace("Firebase: ", ""));
    }
    setLoading(false);
  };

  return (
    <div className="page-fade" style={{ minHeight: "80vh", display: "flex", alignItems: "center" }}>
      <div className="container py-5">
        <div className="auth-card">
          <div className="text-center mb-4">
            <div style={{ fontFamily: "Orbitron", fontWeight: 900, fontSize: "1.3rem", background: "var(--gradient)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", marginBottom: 8 }}>
              ⬡ SHOPSHOPIE
            </div>
            <div style={{ display: "flex", gap: 0, border: "1px solid var(--border)", borderRadius: 6, overflow: "hidden" }}>
              {["login", "register"].map(m => (
                <button key={m} onClick={() => setMode(m)} style={{
                  flex: 1, padding: "10px", fontFamily: "Orbitron", fontSize: "0.65rem", letterSpacing: 2,
                  background: mode === m ? "var(--gradient)" : "transparent",
                  color: mode === m ? "#000" : "var(--muted)", border: "none", cursor: "pointer"
                }}>
                  {m.toUpperCase()}
                </button>
              ))}
            </div>
          </div>

          {error && <div className="cyber-alert cyber-alert-error">{error}</div>}

          {mode === "register" && (
            <div className="cyber-form-group">
              <label className="cyber-label">FULL NAME</label>
              <input className="cyber-input" placeholder="John Doe" value={form.name}
                onChange={e => setForm(f => ({ ...f, name: e.target.value }))} />
            </div>
          )}
          <div className="cyber-form-group">
            <label className="cyber-label">EMAIL ADDRESS</label>
            <input type="email" className="cyber-input" placeholder="your@email.com" value={form.email}
              onChange={e => setForm(f => ({ ...f, email: e.target.value }))} />
          </div>
          <div className="cyber-form-group">
            <label className="cyber-label">PASSWORD</label>
            <input type="password" className="cyber-input" placeholder="••••••••" value={form.password}
              onChange={e => setForm(f => ({ ...f, password: e.target.value }))} />
          </div>
          <button className="btn-primary-cyber" style={{ width: "100%" }} onClick={handle} disabled={loading}>
            {loading ? "PROCESSING..." : mode === "login" ? "SIGN IN" : "CREATE ACCOUNT"}
          </button>
          <div style={{ textAlign: "center", marginTop: 20, color: "var(--muted)", fontSize: "0.85rem" }}>
            {mode === "login" ? "New here? " : "Have an account? "}
            <button onClick={() => setMode(mode === "login" ? "register" : "login")}
              style={{ background: "none", border: "none", color: "var(--cyan)", cursor: "pointer", fontFamily: "Rajdhani", fontWeight: 600 }}>
              {mode === "login" ? "Create Account" : "Sign In"}
            </button>
          </div>
        </div>
      </div>
    </div>
  );
};

// ─── ACCOUNT PAGE ─────────────────────────────────────────────────────────────
const AccountPage = ({ user, setUser, setPage, wishlist, showToast }) => {
  const [tab, setTab] = useState("orders");
  const [orders, setOrders] = useState([]);

  useEffect(() => {
    if (!user) return;
    const q = query(collection(db, "orders"), where("userId", "==", user.uid));
    getDocs(q).then(snap => setOrders(snap.docs.map(d => ({ id: d.id, ...d.data() }))));
  }, [user]);

  if (!user) {
    return (
      <div className="container py-5 text-center">
        <h3 style={{ fontFamily: "Orbitron", color: "var(--cyan)", marginBottom: 20 }}>SIGN IN TO VIEW ACCOUNT</h3>
        <button className="btn-primary-cyber" onClick={() => setPage({ name: "login" })}>LOGIN</button>
      </div>
    );
  }

  const logout = () => { signOut(auth); setUser(null); setPage({ name: "home" }); showToast("Signed out successfully"); };

  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">⬡ MY ACCOUNT</h1>
        <p className="page-hero-sub">{user.email}</p>
      </div>
      <div className="container py-5">
        <div className="row g-4">
          <div className="col-12 col-md-3">
            <div className="account-nav">
              {[["orders", "📦 Orders"], ["wishlist", "♡ Wishlist"], ["settings", "⚙ Settings"]].map(([k, l]) => (
                <button key={k} className={`account-nav-item ${tab === k ? "active" : ""}`} onClick={() => setTab(k)}>
                  {l}
                </button>
              ))}
              <button className="account-nav-item" onClick={logout} style={{ color: "#ff6060" }}>
                ⏻ Sign Out
              </button>
            </div>
          </div>

          <div className="col-12 col-md-9">
            {tab === "orders" && (
              <div>
                <div className="filter-title">ORDER HISTORY</div>
                {orders.length === 0 ? (
                  <div className="text-center py-4">
                    <p style={{ color: "var(--muted)" }}>No orders yet.</p>
                    <button className="btn-outline-cyber mt-3" onClick={() => setPage({ name: "shop" })}>START SHOPPING</button>
                  </div>
                ) : (
                  orders.map(order => (
                    <div key={order.id} style={{ background: "var(--card)", border: "1px solid var(--border)", borderRadius: 12, padding: 20, marginBottom: 16 }}>
                      <div className="d-flex justify-content-between flex-wrap gap-2 mb-2">
                        <span style={{ fontFamily: "Orbitron", fontSize: "0.65rem", color: "var(--cyan)" }}>
                          ORDER #{order.id.slice(0, 8).toUpperCase()}
                        </span>
                        <span className={`status-badge status-${order.status || "processing"}`}>
                          {(order.status || "processing").toUpperCase()}
                        </span>
                      </div>
                      <div style={{ color: "var(--muted)", fontSize: "0.85rem" }}>
                        {order.items?.length} item{order.items?.length !== 1 ? "s" : ""} • Total: ${order.total?.toFixed(2)}
                      </div>
                    </div>
                  ))
                )}
              </div>
            )}

            {tab === "wishlist" && (
              <div>
                <div className="filter-title">MY WISHLIST</div>
                <div className="row g-3">
                  {wishlist.length === 0 ? (
                    <p style={{ color: "var(--muted)" }}>Your wishlist is empty.</p>
                  ) : wishlist.map(p => (
                    <div key={p.id} className="col-12 col-sm-6">
                      <div style={{ background: "var(--card)", border: "1px solid var(--border)", borderRadius: 12, padding: 16, display: "flex", gap: 16, alignItems: "center" }}>
                        <img src={p.img} alt="" style={{ width: 60, height: 44, objectFit: "cover", borderRadius: 8 }} />
                        <div style={{ flex: 1 }}>
                          <div style={{ fontSize: "0.85rem", fontWeight: 600 }}>{p.name}</div>
                          <div style={{ fontFamily: "Orbitron", color: "var(--cyan)", fontSize: "0.8rem" }}>${p.price}</div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {tab === "settings" && (
              <div>
                <div className="filter-title">PROFILE SETTINGS</div>
                <div className="cyber-form-group">
                  <label className="cyber-label">EMAIL ADDRESS</label>
                  <input className="cyber-input" value={user.email} readOnly style={{ opacity: 0.7 }} />
                </div>
                <div className="cyber-form-group">
                  <label className="cyber-label">DISPLAY NAME</label>
                  <input className="cyber-input" placeholder="Your name" />
                </div>
                <button className="btn-primary-cyber">SAVE CHANGES</button>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
};

