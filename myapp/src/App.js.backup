// ── SHOP ─────────────────────────────────────────────────────
function ShopPage({ onNav, wishlist, onAddToCart, onToggleWish, cart, initialCategory }) {
  const [filter, setFilter] = useState({ cats:initialCategory?[initialCategory]:[], maxPrice:600, sort:"featured", minRating:0 });
  const [page,   setPage]   = useState(1);
  const PER = 12;
  const allCats = [...new Set(PRODUCTS.map(p=>p.cat))].sort();

  const filtered = useMemo(()=>{
    let list=PRODUCTS.filter(p=>{
      if(filter.cats.length&&!filter.cats.includes(p.cat)) return false;
      if(p.price>filter.maxPrice) return false;
      if(p.rating<filter.minRating) return false;
      return true;
    });
    if(filter.sort==="price-asc")  list=[...list].sort((a,b)=>a.price-b.price);
    if(filter.sort==="price-desc") list=[...list].sort((a,b)=>b.price-a.price);
    if(filter.sort==="rating")     list=[...list].sort((a,b)=>b.rating-a.rating);
    if(filter.sort==="reviews")    list=[...list].sort((a,b)=>b.reviews-a.reviews);
    return list;
  },[filter]);

  const totalPages = Math.ceil(filtered.length/PER);
  const paged      = filtered.slice((page-1)*PER,page*PER);

  const toggleCat = cat => { setFilter(f=>({...f,cats:f.cats.includes(cat)?f.cats.filter(c=>c!==cat):[...f.cats,cat]})); setPage(1); };

  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Shop"}]} title="ALL PRODUCTS" sub={`${filtered.length} products`} onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"grid",gridTemplateColumns:"240px 1fr",gap:32,alignItems:"start"}}>
          {/* Filters */}
          <div style={{...T.surface,padding:18,position:"sticky",top:72}}>
            <div style={{...T.orbitron,fontSize:10,letterSpacing:2,...T.cyan,textTransform:"uppercase",marginBottom:14}}>CATEGORIES</div>
            {allCats.map(cat=>(
              <label key={cat} style={{display:"flex",alignItems:"center",gap:9,padding:"5px 0",cursor:"pointer",fontSize:13,color:filter.cats.includes(cat)?"#e2e8f0":"#64748b"}}>
                <input type="checkbox" checked={filter.cats.includes(cat)} onChange={()=>toggleCat(cat)} style={{accentColor:"#00e5ff",cursor:"pointer"}}/>{cat}
              </label>
            ))}
            <div style={{marginTop:18}}>
              <div style={{...T.orbitron,fontSize:10,letterSpacing:2,...T.cyan,textTransform:"uppercase",marginBottom:7}}>MAX PRICE</div>
              <div style={{...T.cyan,...T.orbitron,fontSize:13,marginBottom:7}}>Up to ${filter.maxPrice}</div>
              <input type="range" min={0} max={600} value={filter.maxPrice} style={{accentColor:"#00e5ff",width:"100%"}} onChange={e=>{setFilter(f=>({...f,maxPrice:parseInt(e.target.value)}));setPage(1);}}/>
            </div>
            <div style={{marginTop:18}}>
              <div style={{...T.orbitron,fontSize:10,letterSpacing:2,...T.cyan,textTransform:"uppercase",marginBottom:7}}>MIN RATING</div>
              <select style={{...T.input,padding:"8px 12px",fontSize:13}} value={filter.minRating} onChange={e=>{setFilter(f=>({...f,minRating:parseFloat(e.target.value)}));setPage(1);}}>
                <option value={0}>Any Rating</option>
                <option value={4}>4★ & above</option>
                <option value={4.5}>4.5★ & above</option>
              </select>
            </div>
            <button onClick={()=>{setFilter({cats:[],maxPrice:600,sort:"featured",minRating:0});setPage(1);}} style={{...T.btnGhost,width:"100%",justifyContent:"center",padding:9,fontSize:10,marginTop:16}}>RESET FILTERS</button>
          </div>
          {/* Products */}
          <div>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:24,flexWrap:"wrap",gap:12}}>
              <span style={{color:"#64748b",fontSize:13}}>{filtered.length} results</span>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                <span style={{color:"#64748b",fontSize:12}}>Sort:</span>
                <select style={{...T.input,width:"auto",padding:"7px 12px",fontSize:13}} value={filter.sort} onChange={e=>{setFilter(f=>({...f,sort:e.target.value}));setPage(1);}}>
                  <option value="featured">Featured</option>
                  <option value="price-asc">Price: Low → High</option>
                  <option value="price-desc">Price: High → Low</option>
                  <option value="rating">Best Rated</option>
                  <option value="reviews">Most Reviewed</option>
                </select>
              </div>
            </div>
            {paged.length===0 ? (
              <div style={{textAlign:"center",padding:"72px 0"}}>
                <div style={{fontSize:"3rem",marginBottom:16}}>🔍</div>
                <p style={{color:"#64748b"}}>No products match your filters.</p>
              </div>
            ) : (
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:18}}>
                {paged.map((p,i)=><ProductCard key={p.id} p={p} onNav={onNav} wishlist={wishlist} onAddToCart={onAddToCart} onToggleWish={onToggleWish} inCart={cart.some(c=>c.id===p.id)} animDelay={i*30}/>)}
              </div>
            )}
            <Pagination page={page} total={totalPages} onChange={n=>{setPage(n);window.scrollTo({top:0,behavior:"smooth"});}}/>
          </div>
        </div>
      </div>
    </div>
  );
}

// ── PRODUCT DETAIL ────────────────────────────────────────────
function ProductPage({ productId, onNav, onAddToCart, onToggleWish, wishlist, cart }) {
  const p       = PRODUCTS.find(x=>x.id===productId);
  const [qty,   setQty]   = useState(1);
  const [tab,   setTab]   = useState("desc");
  if (!p) return <div style={{padding:72,textAlign:"center",color:"#64748b"}}>Product not found.</div>;
  const wished  = wishlist.some(i=>i.id===p.id);
  const inCart  = cart.some(c=>c.id===p.id);
  const related = PRODUCTS.filter(x=>x.cat===p.cat&&x.id!==p.id).slice(0,4);
  const discount= p.orig?Math.round((p.orig-p.price)/p.orig*100):0;
  const fakeRevs=[
    {author:"Alex M.",rating:5,text:"Absolutely love this product! Great quality and fast delivery."},
    {author:"Sarah K.",rating:p.rating>=4.5?5:4,text:"Very good value for money. Does exactly what it says on the box."},
    {author:"James R.",rating:p.rating>=4.7?5:4,text:"Solid build quality. Would definitely recommend to a friend."},
  ];
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Shop",nav:"shop"},{label:p.cat,nav:"shop"},{label:p.name}]} title="" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:48,alignItems:"start"}}>
          {/* Image */}
          <div style={{...T.surface,aspectRatio:"1",display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",position:"relative",background:"#f8f9fa",borderRadius:12}}>
            <ProductImage src={p.image1} alt={p.name} emoji={p.e} mode="contain" style={{width:"100%",height:"100%",objectFit:"contain",padding:24}}/>
            {discount>0 && <span style={{position:"absolute",top:14,left:14,background:"#ff6b35",color:"#fff",fontSize:11,fontWeight:700,padding:"4px 12px",borderRadius:4,...T.orbitron,zIndex:2}}>-{discount}%</span>}
          </div>
          {/* Info */}
          <div>
            <div style={{fontSize:10,letterSpacing:2,...T.cyan,textTransform:"uppercase",marginBottom:8}}>{p.cat}</div>
            <h1 style={{...T.orbitron,fontSize:"clamp(1.2rem,2.5vw,1.7rem)",color:"#fff",fontWeight:700,marginBottom:12}}>{p.name}</h1>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:20}}>
              <span style={{color:"#f59e0b",fontSize:16}}>{stars(p.rating)}</span>
              <span style={{fontWeight:700}}>{p.rating}</span>
              <span style={{color:"#64748b",fontSize:13}}>({p.reviews?.toLocaleString()} reviews)</span>
            </div>
            <div style={{marginBottom:24}}>
              <span style={{...T.orbitron,fontSize:"2rem",fontWeight:700,color:"#00e5ff"}}>${p.price}</span>
              {p.orig&&<span style={{fontSize:14,color:"#64748b",textDecoration:"line-through",marginLeft:10}}>${p.orig}</span>}
              {p.orig&&<span style={{marginLeft:8,background:"rgba(255,107,53,.15)",color:"#ff6b35",fontSize:11,padding:"2px 8px",borderRadius:4}}>SAVE ${(p.orig-p.price).toFixed(2)}</span>}
            </div>
            <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:20}}>
              <span style={{color:"#64748b",fontSize:12}}>QTY:</span>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                {["−","+"].map((sym,i)=>(
                  <button key={sym} onClick={()=>setQty(q=>i===0?Math.max(1,q-1):q+1)} style={{...T.input,padding:0,width:36,height:36,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",fontSize:18}}>{sym}</button>
                ))}
                <span style={{...T.orbitron,fontWeight:700,fontSize:16,minWidth:28,textAlign:"center"}}>{qty}</span>
              </div>
            </div>
            <div style={{display:"flex",gap:12,flexWrap:"wrap",marginBottom:20}}>
              <button onClick={()=>onAddToCart(p.id,qty)} style={{...T.btnCyan,flex:1,justifyContent:"center"}}>🛒 ADD TO CART</button>
              <button onClick={()=>onToggleWish(p.id)} style={{...T.btnGhost,borderColor:wished?"#ec4899":"#1a2640",color:wished?"#ec4899":"#64748b",padding:"11px 16px"}}>{wished?"♥":"♡"}</button>
            </div>
            <div style={{display:"flex",gap:16,padding:"16px 0",borderTop:"1px solid #1a2640",flexWrap:"wrap"}}>
              {[["🚚","Free Shipping"],["↩","30-Day Returns"],["🛡","2-Year Warranty"]].map(([ic,txt])=>(
                <div key={txt} style={{display:"flex",alignItems:"center",gap:6,fontSize:12,color:"#64748b"}}><span>{ic}</span>{txt}</div>
              ))}
            </div>
          </div>
        </div>
        {/* Tabs */}
        <div style={{marginTop:48}}>
          <div style={{borderBottom:"1px solid #1a2640",display:"flex",gap:0,marginBottom:24}}>
            {["desc","specs","reviews"].map(t=>(
              <button key={t} onClick={()=>setTab(t)} style={{background:"none",border:"none",borderBottom:`2px solid ${tab===t?"#00e5ff":"transparent"}`,color:tab===t?"#00e5ff":"#64748b",...T.orbitron,fontSize:10,letterSpacing:2,padding:"9px 14px",cursor:"pointer",textTransform:"uppercase",marginBottom:-1}}>
                {t==="desc"?"DESCRIPTION":t==="specs"?"SPECIFICATIONS":"REVIEWS"}
              </button>
            ))}
          </div>
          {tab==="desc" && <p style={{color:"#94a3b8",lineHeight:1.8,maxWidth:640,...T.rajdhani}}>{p.desc}</p>}
          {tab==="specs" && <div style={{maxWidth:500}}>{Object.entries(p.specs||{}).map(([k,v])=>(
            <div key={k} style={{display:"flex",padding:"9px 0",borderBottom:"1px solid #1a2640",fontSize:13}}>
              <span style={{color:"#64748b",width:140,flexShrink:0}}>{k}</span>
              <span style={{color:"#e2e8f0",fontWeight:600}}>{v}</span>
            </div>
          ))}</div>}
          {tab==="reviews" && <div style={{maxWidth:640}}>
            {fakeRevs.map((r,i)=>(
              <div key={i} style={{...T.surface,padding:16,marginBottom:10}}>
                <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:8}}>
                  <div style={{width:34,height:34,borderRadius:"50%",background:"rgba(0,229,255,.1)",border:"1px solid rgba(0,229,255,.2)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:600,color:"#00e5ff"}}>{r.author[0]}</div>
                  <div>
                    <div style={{fontSize:13,fontWeight:600}}>{r.author}</div>
                    <div style={{fontSize:11,color:"#f59e0b"}}>{"★".repeat(r.rating)}</div>
                  </div>
                </div>
                <p style={{fontSize:13,color:"#94a3b8",lineHeight:1.6}}>{r.text}</p>
              </div>
            ))}
          </div>}
        </div>
        {/* Related */}
        {related.length>0 && (
          <div style={{marginTop:64}}>
            <SectionHeader tag="Same Category" title="RELATED PRODUCTS"/>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:18}}>
              {related.map((rp,i)=><ProductCard key={rp.id} p={rp} onNav={onNav} wishlist={wishlist} onAddToCart={onAddToCart} onToggleWish={onToggleWish} inCart={cart.some(c=>c.id===rp.id)} animDelay={i*50}/>)}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ── CART PAGE ─────────────────────────────────────────────────
function CartPage({ cart, onNav, onRemove, onUpdateQty }) {
  const subtotal = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const shipping = subtotal>=75?0:9.99;
  const tax      = subtotal*.08;
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Cart"}]} title="SHOPPING CART" sub={`${cart.reduce((s,i)=>s+i.qty,0)} items`} onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        {cart.length===0 ? (
          <div style={{textAlign:"center",padding:"72px 0"}}>
            <div style={{fontSize:"3rem",marginBottom:16}}>🛒</div>
            <h2 style={{...T.orbitron,color:"#fff",marginBottom:12}}>YOUR CART IS EMPTY</h2>
            <p style={{color:"#64748b",marginBottom:28}}>Looks like you haven't added anything yet.</p>
            <button onClick={()=>onNav("shop")} style={T.btnCyan}>BROWSE PRODUCTS</button>
          </div>
        ) : (
          <div style={{display:"grid",gridTemplateColumns:"1fr 340px",gap:32,alignItems:"start"}}>
            <div style={{...T.surface,padding:22}}>
              {cart.map(item=>(
                <div key={item.id} style={{display:"flex",gap:14,padding:"14px 0",borderBottom:"1px solid #1a2640",alignItems:"center"}}>
                  <div style={{width:64,height:48,background:"#0a0f1e",borderRadius:8,overflow:"hidden",flexShrink:0,cursor:"pointer"}} onClick={()=>onNav("product",item.id)}>
                    <ProductImage src={item.image1} alt={item.name} emoji={item.e} style={{width:"100%",height:"100%",objectFit:"cover"}}/>
                  </div>
                  <div style={{flex:1}}>
                    <div style={{fontSize:13,fontWeight:700,marginBottom:4,cursor:"pointer"}} onClick={()=>onNav("product",item.id)}>{item.name}</div>
                    <div style={{...T.cyan,...T.orbitron,fontSize:12}}>${item.price}</div>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:7}}>
                    {["−","+"].map((sym,i)=>(
                      <button key={sym} onClick={()=>onUpdateQty(item.id,item.qty+(i===0?-1:1))} style={{background:"#070b14",border:"1px solid #1a2640",color:"#e2e8f0",width:28,height:28,borderRadius:6,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>{sym}</button>
                    ))}
                    <span style={{...T.orbitron,fontSize:12,minWidth:20,textAlign:"center"}}>{item.qty}</span>
                  </div>
                  <div style={{...T.orbitron,fontSize:13,fontWeight:700,...T.cyan,minWidth:64,textAlign:"right"}}>${(item.price*item.qty).toFixed(2)}</div>
                  <button onClick={()=>onRemove(item.id)} style={{background:"none",border:"none",color:"#ef4444",cursor:"pointer",fontSize:16,padding:"0 4px"}}>✕</button>
                </div>
              ))}
            </div>
            <div style={{...T.surface,padding:22,position:"sticky",top:80}}>
              <div style={{...T.orbitron,fontSize:12,fontWeight:700,letterSpacing:2,...T.cyan,marginBottom:18}}>ORDER SUMMARY</div>
              {[["Subtotal",`$${subtotal.toFixed(2)}`],["Shipping",shipping===0?"FREE":`$${shipping.toFixed(2)}`],["Tax (8%)",`$${tax.toFixed(2)}`]].map(([k,v])=>(
                <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"9px 0",borderBottom:"1px solid #1a2640",fontSize:14}}>
                  <span style={{color:"#64748b"}}>{k}</span><span>{v}</span>
                </div>
              ))}
              <div style={{display:"flex",justifyContent:"space-between",padding:"12px 0",...T.orbitron,fontSize:17,fontWeight:700,color:"#00e5ff"}}>
                <span>TOTAL</span><span>${(subtotal+shipping+tax).toFixed(2)}</span>
              </div>
              {shipping>0&&<div style={{background:"rgba(0,229,255,.07)",border:"1px solid rgba(0,229,255,.2)",borderRadius:8,padding:"10px 14px",fontSize:12,color:"#00e5ff",marginBottom:16}}>Add ${(75-subtotal).toFixed(2)} more for free shipping!</div>}
              <button onClick={()=>onNav("checkout")} style={{...T.btnCyan,width:"100%",justifyContent:"center",marginBottom:10,padding:14}}>PROCEED TO CHECKOUT</button>
              <button onClick={()=>onNav("shop")} style={{...T.btnGhost,width:"100%",justifyContent:"center",padding:12}}>CONTINUE SHOPPING</button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ── CHECKOUT ──────────────────────────────────────────────────
function CheckoutPage({ cart, onNav, onPlaceOrder }) {
  const [step, setStep]   = useState(1);
  const [form, setForm]   = useState({name:"",email:"",address:"",city:"",zip:"",country:"US"});
  const [pay,  setPay]    = useState("card");
  const subtotal = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const shipping = subtotal>=75?0:9.99;
  const total    = (subtotal+shipping+subtotal*.08).toFixed(2);
  const FG = ({label,fkey,type="text",ph})=>(
    <div key={fkey}>
      <label style={T.label}>{label}</label>
      <input style={T.input} type={type} placeholder={ph} value={form[fkey]} onChange={e=>setForm(f=>({...f,[fkey]:e.target.value}))}/>
    </div>
  );
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Cart",nav:"cart"},{label:"Checkout"}]} title="CHECKOUT" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"flex",alignItems:"center",marginBottom:36}}>
          {["Shipping","Payment","Review"].map((lbl,i)=>(
            <div key={lbl} style={{display:"flex",alignItems:"center",flex:1}}>
              <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:7}}>
                <div style={{width:38,height:38,borderRadius:"50%",border:`2px solid ${step>i+1?"#00e5ff":step===i+1?"#00e5ff":"#1a2640"}`,display:"flex",alignItems:"center",justifyContent:"center",...T.orbitron,fontSize:12,color:step>i+1?"#000":step===i+1?"#00e5ff":"#64748b",background:step>i+1?"#00e5ff":"#070b14"}}>{step>i+1?"✓":i+1}</div>
                <span style={{fontSize:10,color:step===i+1?"#00e5ff":"#64748b",letterSpacing:1,textTransform:"uppercase",...T.orbitron}}>{lbl}</span>
              </div>
              {i<2&&<div style={{flex:1,height:1,background:"#1a2640",margin:"0 6px",marginBottom:22}}/>}
            </div>
          ))}
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 320px",gap:32,alignItems:"start"}}>
          <div style={{...T.surface,padding:28}}>
            {step===1&&(
              <div>
                <div style={{...T.orbitron,fontSize:11,...T.cyan,letterSpacing:2,marginBottom:20}}>SHIPPING INFORMATION</div>
                <div style={{display:"grid",gap:16}}>
                  <FG label="Full Name" fkey="name" ph="John Doe"/>
                  <FG label="Email" fkey="email" type="email" ph="you@email.com"/>
                  <FG label="Address" fkey="address" ph="123 Main Street"/>
                  <FG label="City" fkey="city" ph="New York"/>
                  <FG label="ZIP Code" fkey="zip" ph="10001"/>
                  <div><label style={T.label}>Country</label>
                    <select style={T.input} value={form.country} onChange={e=>setForm(f=>({...f,country:e.target.value}))}>
                      {["United States","Canada","United Kingdom","Australia","Germany","France","Pakistan","India"].map(c=><option key={c}>{c}</option>)}
                    </select>
                  </div>
                </div>
                <button onClick={()=>setStep(2)} style={{...T.btnCyan,marginTop:24}}>CONTINUE TO PAYMENT →</button>
              </div>
            )}
            {step===2&&(
              <div>
                <div style={{...T.orbitron,fontSize:11,...T.cyan,letterSpacing:2,marginBottom:20}}>PAYMENT METHOD</div>
                {[["card","💳","Credit / Debit Card"],["paypal","🅿️","PayPal"],["cod","💵","Cash on Delivery"]].map(([id,ic,lbl])=>(
                  <div key={id} onClick={()=>setPay(id)} style={{border:`1px solid ${pay===id?"#00e5ff":"#1a2640"}`,borderRadius:10,padding:14,cursor:"pointer",transition:"all .2s",display:"flex",alignItems:"center",gap:11,marginBottom:8,background:pay===id?"rgba(0,229,255,.05)":"transparent"}}>
                    <span style={{fontSize:"1.4rem"}}>{ic}</span>
                    <span style={{fontWeight:600}}>{lbl}</span>
                    {pay===id&&<span style={{marginLeft:"auto",...T.cyan,fontSize:12}}>✓ Selected</span>}
                  </div>
                ))}
                {pay==="card"&&(
                  <div style={{marginTop:20,display:"grid",gap:14}}>
                    <div><label style={T.label}>Card Number</label><input style={T.input} placeholder="1234 5678 9012 3456"/></div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                      <div><label style={T.label}>Expiry</label><input style={T.input} placeholder="MM/YY"/></div>
                      <div><label style={T.label}>CVV</label><input style={{...T.input}} placeholder="•••"/></div>
                    </div>
                  </div>
                )}
                <div style={{display:"flex",gap:12,marginTop:24}}>
                  <button onClick={()=>setStep(1)} style={T.btnGhost}>← BACK</button>
                  <button onClick={()=>setStep(3)} style={T.btnCyan}>REVIEW ORDER →</button>
                </div>
              </div>
            )}
            {step===3&&(
              <div>
                <div style={{...T.orbitron,fontSize:11,...T.cyan,letterSpacing:2,marginBottom:20}}>REVIEW ORDER</div>
                {cart.map(item=>(
                  <div key={item.id} style={{display:"flex",gap:12,padding:"10px 0",borderBottom:"1px solid #1a2640",alignItems:"center"}}>
                    <div style={{width:40,height:40,borderRadius:6,overflow:"hidden",flexShrink:0}}>
                      <ProductImage src={item.image1} alt={item.name} emoji={item.e} style={{width:"100%",height:"100%",objectFit:"cover"}}/>
                    </div>
                    <div style={{flex:1}}><div style={{fontSize:12,fontWeight:600}}>{item.name}</div><div style={{fontSize:11,color:"#64748b"}}>Qty: {item.qty}</div></div>
                    <div style={{...T.orbitron,fontSize:12,...T.cyan}}>${(item.price*item.qty).toFixed(2)}</div>
                  </div>
                ))}
                <div style={{marginTop:20,padding:16,background:"rgba(0,229,255,.04)",border:"1px solid #1a2640",borderRadius:8,fontSize:13}}>
                  <div style={{color:"#64748b",marginBottom:6}}>Ship to: <span style={{color:"#e2e8f0"}}>{form.name||"—"}, {form.address||"—"}, {form.city}</span></div>
                  <div style={{color:"#64748b"}}>Payment: <span style={{color:"#e2e8f0"}}>{pay==="card"?"Credit Card":pay==="paypal"?"PayPal":"Cash on Delivery"}</span></div>
                </div>
                <div style={{display:"flex",gap:12,marginTop:24}}>
                  <button onClick={()=>setStep(2)} style={T.btnGhost}>← BACK</button>
                  <button onClick={onPlaceOrder} style={{...T.btnCyan,background:"linear-gradient(135deg,#ff6b35,#ff3d00)"}}>PLACE ORDER ✓</button>
                </div>
              </div>
            )}
          </div>
          <div style={{...T.surface,padding:22,position:"sticky",top:80}}>
            <div style={{...T.orbitron,fontSize:10,letterSpacing:2,...T.cyan,marginBottom:16}}>ORDER SUMMARY</div>
            {cart.map(i=>(
              <div key={i.id} style={{display:"flex",gap:8,alignItems:"center",padding:"6px 0",borderBottom:"1px solid #1a2640",fontSize:12}}>
                <div style={{width:28,height:28,borderRadius:4,overflow:"hidden",flexShrink:0}}>
                  <ProductImage src={i.image1} alt={i.name} emoji={i.e} style={{width:"100%",height:"100%",objectFit:"cover"}}/>
                </div>
                <span style={{flex:1}}>{i.name} ×{i.qty}</span>
                <span style={{...T.cyan,...T.orbitron,fontSize:11}}>${(i.price*i.qty).toFixed(2)}</span>
              </div>
            ))}
            {[["Subtotal",`$${subtotal.toFixed(2)}`],["Shipping",shipping===0?"FREE":`$${shipping.toFixed(2)}`],["Tax",`$${(subtotal*.08).toFixed(2)}`]].map(([k,v])=>(
              <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"8px 0",borderBottom:"1px solid #1a2640",fontSize:13}}><span style={{color:"#64748b"}}>{k}</span><span>{v}</span></div>
            ))}
            <div style={{display:"flex",justifyContent:"space-between",padding:"12px 0",...T.orbitron,fontSize:16,fontWeight:700,color:"#00e5ff"}}><span>TOTAL</span><span>${total}</span></div>
          </div>
        </div>
      </div>
    </div>
  );
}

// ── ORDER CONFIRM ─────────────────────────────────────────────
function OrderConfirmPage({ onNav, orderId }) {
  return (
    <div style={{minHeight:"80vh",display:"flex",alignItems:"center",justifyContent:"center",padding:"40px 20px"}}>
      <div style={{maxWidth:540,width:"100%",textAlign:"center"}} className="fade-up">
        <div style={{width:76,height:76,borderRadius:"50%",background:"rgba(34,197,94,.15)",border:"2px solid #22c55e",display:"flex",alignItems:"center",justifyContent:"center",fontSize:"2.2rem",margin:"0 auto 22px",color:"#22c55e"}}>✓</div>
        <div style={{display:"inline-block",background:"rgba(0,229,255,.1)",border:"1px solid rgba(0,229,255,.3)",color:"#00e5ff",fontSize:10,letterSpacing:3,padding:"6px 16px",borderRadius:4,marginBottom:16,...T.orbitron}}>ORDER CONFIRMED</div>
        <h1 style={{...T.orbitron,fontSize:"clamp(1.4rem,4vw,1.9rem)",color:"#fff",marginBottom:10}}>THANK YOU!</h1>
        <p style={{color:"#64748b",marginBottom:28}}>Your order #{orderId} has been placed. A confirmation email has been sent.</p>
        <div style={{display:"flex",gap:12,justifyContent:"center",flexWrap:"wrap"}}>
          <button onClick={()=>onNav("account")} style={T.btnCyan}>📦 VIEW ORDERS</button>
          <button onClick={()=>onNav("shop")} style={T.btnGhost}>CONTINUE SHOPPING</button>
        </div>
      </div>
    </div>
  );
}

// ── DEALS ─────────────────────────────────────────────────────
function DealsPage({ onNav, wishlist, onAddToCart, onToggleWish, cart, onToast }) {
  const deals = PRODUCTS.filter(p=>p.orig);
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Deals"}]} title="DEALS & OFFERS" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{background:"linear-gradient(135deg,rgba(255,107,53,.1),rgba(0,229,255,.05))",border:"1px solid rgba(255,107,53,.3)",borderRadius:12,padding:"22px 28px",marginBottom:36,display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:14}}>
          <div>
            <div style={{...T.orbitron,fontSize:"1.2rem",fontWeight:700,color:"#fff"}}>FREE SHIPPING</div>
            <div style={{color:"#64748b",fontSize:13}}>On all orders over $75 — use code <strong style={{color:"#ff6b35"}}>SAVE75</strong></div>
          </div>
          <span onClick={()=>onToast("Code SAVE75 copied!","success")} style={{background:"#ff6b35",color:"#fff",...T.orbitron,fontSize:13,fontWeight:700,padding:"7px 18px",borderRadius:8,cursor:"pointer"}}>SAVE75</span>
        </div>
        <div style={{display:"flex",alignItems:"center",gap:16,marginBottom:32,flexWrap:"wrap"}}>
          <span style={{color:"#64748b",fontSize:13}}>Flash sale ends in:</span>
          <Countdown endTime={Date.now()+5*3600000+23*60000}/>
        </div>
        <SectionHeader tag="Limited Time" title="ON SALE NOW"/>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:18}}>
          {deals.map((p,i)=><ProductCard key={p.id} p={p} onNav={onNav} wishlist={wishlist} onAddToCart={onAddToCart} onToggleWish={onToggleWish} inCart={cart.some(c=>c.id===p.id)} animDelay={i*30}/>)}
        </div>
      </div>
    </div>
  );
}

// ── WISHLIST ──────────────────────────────────────────────────
function WishlistPage({ wishlist, onNav, onAddToCart, onToggleWish, cart }) {
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Wishlist"}]} title="MY WISHLIST" sub={`${wishlist.length} saved items`} onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        {wishlist.length===0 ? (
          <div style={{textAlign:"center",padding:"72px 0"}}>
            <div style={{fontSize:"3rem",marginBottom:16}}>♡</div>
            <h2 style={{...T.orbitron,color:"#fff",marginBottom:12}}>YOUR WISHLIST IS EMPTY</h2>
            <p style={{color:"#64748b",marginBottom:28}}>Save items you love to your wishlist.</p>
            <button onClick={()=>onNav("shop")} style={T.btnCyan}>BROWSE PRODUCTS</button>
          </div>
        ) : (
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:18}}>
            {wishlist.map((p,i)=><ProductCard key={p.id} p={p} onNav={onNav} wishlist={wishlist} onAddToCart={onAddToCart} onToggleWish={onToggleWish} inCart={cart.some(c=>c.id===p.id)} animDelay={i*30}/>)}
          </div>
        )}
      </div>
    </div>
  );
}

// ── SEARCH ────────────────────────────────────────────────────
function SearchPage({ onNav, wishlist, onAddToCart, onToggleWish, cart }) {
  const [query,    setQuery]    = useState("");
  const [results,  setResults]  = useState([]);
  const [searched, setSearched] = useState(false);
  const run = () => {
    if(!query.trim()) return;
    const q=query.toLowerCase();
    setResults(PRODUCTS.filter(p=>p.name.toLowerCase().includes(q)||p.cat.toLowerCase().includes(q)||(p.desc||"").toLowerCase().includes(q)));
    setSearched(true);
  };
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Search"}]} title="SEARCH" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"flex",maxWidth:560,marginBottom:36}}>
          <input value={query} onChange={e=>setQuery(e.target.value)} onKeyDown={e=>e.key==="Enter"&&run()} placeholder="Search products, categories, brands…" style={{...T.input,borderRadius:"8px 0 0 8px"}}/>
          <button onClick={run} style={{...T.btnCyan,borderRadius:"0 8px 8px 0"}}>🔍 SEARCH</button>
        </div>
        {!searched ? (
          <div>
            <p style={{color:"#64748b",marginBottom:14}}>Popular searches:</p>
            <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
              {["Running Shoes","Wireless Headphones","Yoga Mat","Vitamin C Serum","Board Games","Smart Watch","Travel Backpack"].map(tag=>(
                <span key={tag} onClick={()=>{setQuery(tag);setTimeout(run,0);}} style={{background:"#0d1626",border:"1px solid #1a2640",color:"#64748b",padding:"4px 11px",borderRadius:20,fontSize:11,cursor:"pointer",transition:"all .2s"}}>{tag}</span>
              ))}
            </div>
          </div>
        ) : (
          <div>
            <p style={{color:"#64748b",marginBottom:24}}>{results.length} results for "{query}"</p>
            {results.length===0 ? (
              <div style={{textAlign:"center",padding:"48px 0"}}>
                <div style={{fontSize:"2.5rem",marginBottom:12}}>🔍</div>
                <p style={{color:"#64748b"}}>No products found. Try a different search term.</p>
              </div>
            ) : (
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:18}}>
                {results.map((p,i)=><ProductCard key={p.id} p={p} onNav={onNav} wishlist={wishlist} onAddToCart={onAddToCart} onToggleWish={onToggleWish} inCart={cart.some(c=>c.id===p.id)} animDelay={i*30}/>)}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

// ── BLOG ──────────────────────────────────────────────────────
function BlogPage({ onNav }) {
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Blog"}]} title="OUR BLOG" sub="Buying guides, reviews & lifestyle tips" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(300px,1fr))",gap:24}}>
          {BLOG_POSTS.map(post=>(
            <div key={post.id} style={{...T.surface,overflow:"hidden",cursor:"pointer",transition:"all .3s"}}
              onMouseEnter={e=>{e.currentTarget.style.borderColor="#00e5ff";e.currentTarget.style.transform="translateY(-4px)";}}
              onMouseLeave={e=>{e.currentTarget.style.borderColor="#1a2640";e.currentTarget.style.transform="";}}>
              <div style={{height:160,background:"#0a0f1e",display:"flex",alignItems:"center",justifyContent:"center",fontSize:64}}>{post.e}</div>
              <div style={{padding:20}}>
                <div style={{display:"flex",gap:12,marginBottom:12,fontSize:11,color:"#64748b"}}>
                  <span style={{color:"#00e5ff"}}>{post.cat}</span>
                  <span>{post.date}</span>
                  <span>{post.read} read</span>
                </div>
                <h3 style={{...T.orbitron,fontSize:14,color:"#fff",marginBottom:10,lineHeight:1.4}}>{post.title}</h3>
                <p style={{color:"#64748b",fontSize:13,lineHeight:1.6}}>{post.excerpt}</p>
                <div style={{marginTop:16,...T.cyan,fontSize:12,...T.orbitron,letterSpacing:1}}>READ MORE →</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ── SUPPORT ───────────────────────────────────────────────────
function SupportPage({ onNav, onToast }) {
  const [openFaq, setOpenFaq] = useState(null);
  const [form, setForm] = useState({name:"",email:"",orderId:"",subject:"Order Issue",message:""});
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Support"}]} title="HELP CENTER" sub="Get answers to your questions" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px"}}>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:16,marginBottom:48}}>
          {[["💬","Live Chat","Available 24/7","#00e5ff"],["✉️","Email","support@megastore.com","#a855f7"],["📞","Phone","1-800-MEGASHOP","#ff6b35"]].map(([ic,t,s,c])=>(
            <div key={t} onClick={()=>onToast(`Connecting to ${t}…`,"info")} style={{...T.surface,padding:22,textAlign:"center",cursor:"pointer",transition:"all .3s"}}
              onMouseEnter={e=>e.currentTarget.style.borderColor=c}
              onMouseLeave={e=>e.currentTarget.style.borderColor="#1a2640"}>
              <span style={{fontSize:"1.9rem",display:"block",marginBottom:10}}>{ic}</span>
              <div style={{...T.orbitron,fontSize:12,fontWeight:700,color:"#fff",marginBottom:3}}>{t}</div>
              <div style={{fontSize:12,color:"#64748b"}}>{s}</div>
            </div>
          ))}
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:32,alignItems:"start"}}>
          <div>
            <h2 style={{...T.orbitron,fontSize:"1.1rem",color:"#fff",marginBottom:22}}>FREQUENTLY ASKED QUESTIONS</h2>
            {FAQS.map((faq,i)=>(
              <div key={i} style={{border:"1px solid #1a2640",borderRadius:8,marginBottom:7,overflow:"hidden"}}>
                <div onClick={()=>setOpenFaq(openFaq===i?null:i)} style={{padding:"14px 18px",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center",background:"rgba(13,22,38,.95)",userSelect:"none"}}>
                  <span style={{fontWeight:600,fontSize:13}}>{faq.q}</span>
                  <span style={{...T.cyan,display:"inline-block",transform:openFaq===i?"rotate(180deg)":"none",transition:"transform .2s"}}>▼</span>
                </div>
                {openFaq===i&&<div style={{padding:"14px 18px",background:"rgba(0,229,255,.03)",fontSize:13,color:"#64748b",lineHeight:1.8,borderTop:"1px solid #1a2640"}}>{faq.a}</div>}
              </div>
            ))}
          </div>
          <div style={{...T.surface,padding:22}}>
            <div style={{...T.orbitron,fontSize:12,fontWeight:700,letterSpacing:2,...T.cyan,marginBottom:18}}>CONTACT US</div>
            <div style={{display:"flex",flexDirection:"column",gap:13}}>
              {[["Your Name","name","text","John Doe"],["Email","email","email","you@email.com"],["Order ID (optional)","orderId","text","#MS12345"]].map(([lbl,key,type,ph])=>(
                <div key={key}><label style={T.label}>{lbl}</label><input style={T.input} type={type} placeholder={ph} value={form[key]} onChange={e=>setForm(f=>({...f,[key]:e.target.value}))}/></div>
              ))}
              <div><label style={T.label}>Subject</label>
                <select style={T.input} value={form.subject} onChange={e=>setForm(f=>({...f,subject:e.target.value}))}>
                  {["Order Issue","Return Request","Product Question","Technical Support","Billing","Other"].map(s=><option key={s}>{s}</option>)}
                </select>
              </div>
              <div><label style={T.label}>Message</label>
                <textarea style={{...T.input,resize:"vertical"}} rows={4} placeholder="Describe your issue…" value={form.message} onChange={e=>setForm(f=>({...f,message:e.target.value}))}/>
              </div>
            </div>
            <button onClick={()=>{if(!form.name||!form.email||!form.message){onToast("Please fill Name, Email and Message","error");return;} onToast("Message sent! We'll reply within 24 hours.","success"); setForm({name:"",email:"",orderId:"",subject:"Order Issue",message:""}); }}
              style={{...T.btnCyan,width:"100%",justifyContent:"center",marginTop:16}}>✉ SEND MESSAGE</button>
          </div>
        </div>
      </div>
    </div>
  );
}

// ── ACCOUNT ───────────────────────────────────────────────────
function AccountPage({ onNav }) {
  return (
    <div>
      <PageBanner crumbs={[{label:"Home",nav:"home"},{label:"Account"}]} title="MY ACCOUNT" onNav={onNav}/>
      <div className="container" style={{padding:"36px 16px 72px",textAlign:"center"}}>
        <div style={{maxWidth:420,margin:"0 auto"}} className="fade-up">
          <div style={{fontSize:"3rem",marginBottom:16}}>👤</div>
          <h2 style={{...T.orbitron,color:"#fff",marginBottom:12}}>SIGN IN TO YOUR ACCOUNT</h2>
          <p style={{color:"#64748b",marginBottom:28}}>Access your orders, wishlist and profile settings.</p>
          <div style={{...T.surface,padding:28,maxWidth:380,margin:"0 auto"}}>
            <div style={{marginBottom:14}}><label style={T.label}>Email Address</label><input style={T.input} type="email" placeholder="you@email.com"/></div>
            <div style={{marginBottom:20}}><label style={T.label}>Password</label><input style={T.input} type="password" placeholder="••••••••"/></div>
            <button style={{...T.btnCyan,width:"100%",justifyContent:"center",marginBottom:12}}>SIGN IN</button>
            <button style={{...T.btnGhost,width:"100%",justifyContent:"center"}}>CREATE ACCOUNT</button>
            <div style={{textAlign:"center",marginTop:14}}><span style={{...T.cyan,fontSize:12,cursor:"pointer"}}>Forgot your password?</span></div>
          </div>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════
//  MAIN APP
// ═══════════════════════════════════════════════════════════════
export default function MegaStore() {
  useGlobalStyles();

  const [page,          setPage]          = useState("home");
  const [pageData,      setPageData]      = useState({});
  const [cart,          setCart]          = useState(()=>{ try{return JSON.parse(localStorage.getItem("ms_cart")||"[]")}catch{return []} });
  const [wishlist,      setWishlist]      = useState(()=>{ try{return JSON.parse(localStorage.getItem("ms_wl")||"[]")}catch{return []} });
  const [toast,         setToast]         = useState(null);
  const [loading,       setLoading]       = useState(true);
  const [mobileOpen,    setMobileOpen]    = useState(false);
  const [orderId,       setOrderId]       = useState(null);
  const toastTimer = useRef(null);

  useEffect(()=>{ setTimeout(()=>setLoading(false),900); },[]);
  useEffect(()=>{ try{localStorage.setItem("ms_cart",JSON.stringify(cart))}catch{} },[cart]);
  useEffect(()=>{ try{localStorage.setItem("ms_wl",JSON.stringify(wishlist))}catch{} },[wishlist]);

  const showToast = useCallback((msg,type="success")=>{
    setToast({msg,type});
    clearTimeout(toastTimer.current);
    toastTimer.current=setTimeout(()=>setToast(null),3500);
  },[]);

  const onNav = useCallback((pageName,productId=null,category=null)=>{
    setPage(pageName);
    setPageData({productId,category});
    setMobileOpen(false);
    window.scrollTo({top:0,behavior:"smooth"});
  },[]);

  const addToCart = useCallback((id,qty=1)=>{
    const p=PRODUCTS.find(x=>x.id===id); if(!p) return;
    setCart(c=>{ const ex=c.find(i=>i.id===id); if(ex) return c.map(i=>i.id===id?{...i,qty:i.qty+qty}:i); return [...c,{...p,qty}]; });
    showToast(`${p.name.split(" ").slice(0,3).join(" ")} added to cart!`,"success");
  },[showToast]);

  const removeFromCart  = useCallback(id=>setCart(c=>c.filter(i=>i.id!==id)),[]);
  const updateQty       = useCallback((id,qty)=>{ if(qty<1){removeFromCart(id);return;} setCart(c=>c.map(i=>i.id===id?{...i,qty}:i)); },[removeFromCart]);
  const toggleWish      = useCallback(id=>{
    const p=PRODUCTS.find(x=>x.id===id); if(!p) return;
    setWishlist(w=>{ const has=w.some(i=>i.id===id); if(has){showToast("Removed from wishlist","info");return w.filter(i=>i.id!==id);} showToast(`${p.name.split(" ").slice(0,2).join(" ")} added to wishlist!`,"success");return [...w,p]; });
  },[showToast]);

  const placeOrder = useCallback(()=>{
    const oid="MS"+Date.now().toString().slice(-8);
    setOrderId(oid); setCart([]);
    onNav("order-confirm");
    showToast("Order placed successfully! 🎉","success");
  },[onNav,showToast]);

  const cartCount = cart.reduce((s,i)=>s+i.qty,0);

  const NAV_LINKS = [
    {id:"home",label:"HOME"},
    {id:"shop",label:"SHOP"},
    {id:"deals",label:"DEALS"},
    {id:"blog",label:"BLOG"},
    {id:"support",label:"SUPPORT"},
  ];

  if (loading) return (
    <div style={{position:"fixed",inset:0,background:"#070b14",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",zIndex:9999}}>
      <div style={{...T.orbitron,fontSize:"1.6rem",fontWeight:900,color:"#fff",letterSpacing:4,marginBottom:20}}>
        MEGA<span style={{color:"#00e5ff"}}>STORE</span>
      </div>
      <div style={{display:"flex",gap:6}}>
        {[0,1,2].map(i=>(
          <div key={i} style={{width:8,height:8,borderRadius:"50%",background:"#00e5ff",animation:`loadDot .9s ${i*.2}s infinite alternate`}}/>
        ))}
      </div>
    </div>
  );

  const sharedProps = { onNav, wishlist, onAddToCart:addToCart, onToggleWish:toggleWish, cart };

  return (
    <div style={{background:"#070b14",color:"#e2e8f0",minHeight:"100vh",...T.rajdhani}}>
      {/* Promo Banner */}
      <div style={{background:"linear-gradient(90deg,#0a0f1e,rgba(0,229,255,.05),#0a0f1e)",borderBottom:"1px solid #1a2640",padding:"9px 0",overflow:"hidden"}}>
        <div style={{display:"flex",gap:56,whiteSpace:"nowrap",animation:"scrollPromo 28s linear infinite"}}>
          {["⚡ FREE SHIPPING ON ORDERS $75+","🛡 2-YEAR WARRANTY","↩ 30-DAY RETURNS","🏷 CODE SAVE75 FOR FREE SHIPPING","⭐ 50,000+ HAPPY CUSTOMERS",
            "⚡ FREE SHIPPING ON ORDERS $75+","🛡 2-YEAR WARRANTY","↩ 30-DAY RETURNS","🏷 CODE SAVE75 FOR FREE SHIPPING","⭐ 50,000+ HAPPY CUSTOMERS"].map((item,i)=>(
            <span key={i} style={{...T.orbitron,fontSize:10,letterSpacing:2,color:"#00e5ff",display:"inline-flex",alignItems:"center",gap:10}}>{item}</span>
          ))}
        </div>
      </div>

      {/* Header */}
      <nav style={{background:"rgba(7,11,20,.97)",borderBottom:"1px solid #1a2640",padding:"12px 0",position:"sticky",top:0,zIndex:1000,backdropFilter:"blur(20px)"}}>
        <div className="container" style={{display:"flex",alignItems:"center",justifyContent:"space-between",gap:12,padding:"0 16px"}}>
          <div onClick={()=>onNav("home")} style={{...T.orbitron,fontSize:"1.3rem",fontWeight:900,color:"#fff",letterSpacing:3,cursor:"pointer",userSelect:"none",flexShrink:0}}>
            MEGA<span style={{color:"#00e5ff"}}>STORE</span>
          </div>
          <div className="hide-mobile" style={{display:"flex",alignItems:"center",gap:4}}>
            {NAV_LINKS.map(l=>(
              <button key={l.id} onClick={()=>onNav(l.id)} style={{background:"none",border:"none",color:page===l.id?"#00e5ff":"#94a3b8",...T.rajdhani,fontWeight:600,letterSpacing:1,fontSize:14,padding:"8px 12px",cursor:"pointer",transition:"color .2s"}}>{l.label}</button>
            ))}
          </div>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <button onClick={()=>onNav("search")} style={{background:"transparent",border:`1px solid ${page==="search"?"#00e5ff":"#1a2640"}`,color:page==="search"?"#00e5ff":"#e2e8f0",borderRadius:8,padding:"8px 12px",cursor:"pointer",transition:"all .2s",display:"inline-flex",alignItems:"center",gap:6,fontSize:14}}>🔍</button>
            <button onClick={()=>onNav("wishlist")} style={{background:"transparent",border:`1px solid ${page==="wishlist"?"#00e5ff":"#1a2640"}`,color:page==="wishlist"?"#00e5ff":"#e2e8f0",borderRadius:8,padding:"8px 12px",cursor:"pointer",position:"relative",transition:"all .2s",display:"inline-flex",alignItems:"center",gap:6,fontSize:14}}>
              ♡{wishlist.length>0&&<span style={{position:"absolute",top:-6,right:-6,background:"#00e5ff",color:"#070b14",fontSize:10,fontWeight:700,borderRadius:"50%",width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center",...T.orbitron}}>{wishlist.length}</span>}
            </button>
            <button onClick={()=>onNav("cart")} style={{background:page==="cart"?"var(--cyan)":"var(--text)",border:"none",color:page==="cart"?"#000":"#fff",borderRadius:8,padding:"8px 16px",cursor:"pointer",position:"relative",transition:"all .2s",display:"inline-flex",alignItems:"center",gap:8,fontSize:14,...T.orbitron,fontWeight:700,letterSpacing:1}}>
              🛒 <span style={{fontSize:13}}>CART</span>
              {cartCount>0&&<span style={{background:page==="cart"?"#000":"#00e5ff",color:page==="cart"?"#fff":"#070b14",fontSize:10,fontWeight:700,borderRadius:"50%",width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center"}}>{cartCount}</span>}
            </button>
            <button onClick={()=>onNav("account")} style={{background:"transparent",border:"1px solid #1a2640",color:page==="account"?"#00e5ff":"#94a3b8",borderRadius:8,padding:"8px 12px",cursor:"pointer",transition:"all .2s",fontSize:14}} className="hide-mobile">👤</button>
            <button onClick={()=>setMobileOpen(o=>!o)} style={{background:"transparent",border:"1px solid #1a2640",color:"#e2e8f0",borderRadius:8,padding:"8px 12px",cursor:"pointer",fontSize:18,lineHeight:1}} className="hide-desktop">☰</button>
          </div>
        </div>
      </nav>

      {/* Mobile Menu */}
      {mobileOpen&&(
        <div style={{position:"fixed",inset:0,background:"rgba(7,11,20,.98)",zIndex:2000,display:"flex",flexDirection:"column",padding:"28px 24px",backdropFilter:"blur(20px)"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:32}}>
            <div style={{...T.orbitron,fontSize:"1.3rem",fontWeight:900,color:"#fff",letterSpacing:3}}>MEGA<span style={{color:"#00e5ff"}}>STORE</span></div>
            <button onClick={()=>setMobileOpen(false)} style={{background:"none",border:"none",color:"#e2e8f0",fontSize:"1.5rem",cursor:"pointer"}}>✕</button>
          </div>
          {[...NAV_LINKS,{id:"wishlist",label:"WISHLIST"},{id:"account",label:"ACCOUNT"}].map(l=>(
            <div key={l.id} onClick={()=>onNav(l.id)} style={{color:"#94a3b8",...T.orbitron,fontWeight:700,fontSize:"1rem",letterSpacing:3,padding:"16px 0",cursor:"pointer",borderBottom:"1px solid #1a2640"}}>{l.label}</div>
          ))}
        </div>
      )}

      {/* Pages */}
      <main>
        {page==="home"         && <HomePage         {...sharedProps}/>}
        {page==="shop"         && <ShopPage         {...sharedProps} initialCategory={pageData.category}/>}
        {page==="product"      && <ProductPage      {...sharedProps} productId={pageData.productId}/>}
        {page==="cart"         && <CartPage         cart={cart} onNav={onNav} onRemove={removeFromCart} onUpdateQty={updateQty}/>}
        {page==="checkout"     && <CheckoutPage     cart={cart} onNav={onNav} onPlaceOrder={placeOrder}/>}
        {page==="order-confirm"&& <OrderConfirmPage onNav={onNav} orderId={orderId}/>}
        {page==="deals"        && <DealsPage        {...sharedProps} onToast={showToast}/>}
        {page==="wishlist"     && <WishlistPage     {...sharedProps}/>}
        {page==="search"       && <SearchPage       {...sharedProps}/>}
        {page==="blog"         && <BlogPage         onNav={onNav}/>}
        {page==="support"      && <SupportPage      onNav={onNav} onToast={showToast}/>}
        {page==="account"      && <AccountPage      onNav={onNav}/>}
      </main>

      {/* Footer */}
      <footer style={{background:"#0a0f1e",borderTop:"1px solid #1a2640",padding:"56px 0 28px",marginTop:0}}>
        <div className="container" style={{padding:"0 16px"}}>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:36,marginBottom:36}}>
            <div>
              <div style={{...T.orbitron,fontSize:"1.3rem",fontWeight:900,color:"#fff",marginBottom:14}}>MEGA<span style={{color:"#00e5ff"}}>STORE</span></div>
              <p style={{color:"#64748b",fontSize:13,lineHeight:1.7,marginBottom:16,...T.rajdhani}}>Your one-stop shop for Fashion, Electronics, Home, Beauty, Sports, Books and more.</p>
            </div>
            {[
              ["Shop",   ["All Products","Deals","New Arrivals","Best Sellers"]],
              ["Company",["About Us","Blog","Careers","Press"]],
              ["Help",   ["Support","Returns","Shipping","Warranty"]],
              ["Account",["Sign In","My Orders","Wishlist","Cart"]],
            ].map(([hdr,links])=>(
              <div key={hdr}>
                <div style={{...T.orbitron,fontSize:10,letterSpacing:3,color:"#00e5ff",textTransform:"uppercase",marginBottom:18}}>{hdr}</div>
                {links.map(lnk=>(
                  <div key={lnk} onClick={()=>onNav(lnk.toLowerCase().replace(/[^a-z]/g,""))} style={{color:"#64748b",display:"block",marginBottom:9,fontSize:13,cursor:"pointer",transition:"color .2s",...T.rajdhani}}
                    onMouseEnter={e=>e.target.style.color="#00e5ff"}
                    onMouseLeave={e=>e.target.style.color="#64748b"}>{lnk}</div>
                ))}
              </div>
            ))}
          </div>
          <div style={{height:1,background:"linear-gradient(90deg,transparent,#00e5ff,transparent)",opacity:.35,margin:"20px 0"}}/>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:12}}>
            <p style={{color:"#64748b",fontSize:12}}>© 2025 MegaStore. All rights reserved.</p>
            <div style={{display:"flex",gap:8}}>
              {["VISA","PAYPAL","STRIPE","CRYPTO"].map(b=>(
                <span key={b} style={{background:"#0d1626",border:"1px solid #1a2640",borderRadius:4,padding:"3px 8px",fontSize:10,color:"#64748b",...T.orbitron}}>{b}</span>
              ))}
            </div>
          </div>
        </div>
      </footer>

      <Toast toast={toast}/>
    </div>
  );
}