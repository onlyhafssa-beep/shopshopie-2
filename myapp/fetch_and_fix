function apiRequest(url, auth) {
  return new Promise((resolve, reject) => {
    const opts = new URL(url);
    const req = https.request({
      hostname: opts.hostname,
      path: opts.pathname + opts.search,
      method: "GET",
      headers: {
        "Authorization": "Basic " + Buffer.from(auth).toString("base64"),
        "Content-Type": "application/json"
      }
    }, res => {
      let data = "";
      res.on("data", chunk => data += chunk);
      res.on("end", () => {
        try { resolve(JSON.parse(data)); }
        catch(e) { reject(new Error("JSON parse error: " + data.substring(0,200))); }
      });
    });
    req.on("error", reject);
    req.end();
  });
}

async function fetchFolder(folder) {
  const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/resources/image?prefix=megastore/${folder}&max_results=50&type=upload`;
  const auth = `${API_KEY}:${API_SECRET}`;
  const result = await apiRequest(url, auth);
  return result.resources || [];
}

