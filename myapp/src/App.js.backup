//  HELPERS
// ═══════════════════════════════════════════════════════════════
const stars = r => "★".repeat(Math.round(r)) + "☆".repeat(5 - Math.round(r));

// Shared style tokens (inline)
const T = {
  orbitron: { fontFamily:"'Orbitron',monospace" },
  rajdhani: { fontFamily:"'Rajdhani',sans-serif" },
  cyan:     { color:"#00e5ff" },
  muted:    { color:"#64748b" },
  surface:  { background:"rgba(13,22,38,.95)", border:"1px solid #1a2640", borderRadius:12 },
  btnCyan:  { background:"linear-gradient(135deg,#00e5ff,#0080ff)", border:"none", color:"#000", fontFamily:"'Orbitron',monospace", fontSize:11, fontWeight:700, letterSpacing:2, padding:"11px 24px", borderRadius:8, cursor:"pointer", display:"inline-flex", alignItems:"center", gap:7, transition:"all .3s" },
  btnGhost: { background:"transparent", border:"1px solid #1a2640", color:"#94a3b8", fontFamily:"'Orbitron',monospace", fontSize:11, fontWeight:700, letterSpacing:2, padding:"11px 24px", borderRadius:8, cursor:"pointer", display:"inline-flex", alignItems:"center", gap:7, transition:"all .3s" },
  input:    { background:"#0d1626", border:"1px solid #1a2640", color:"#e2e8f0", borderRadius:8, padding:"11px 15px", fontFamily:"'Rajdhani',sans-serif", fontSize:14, outline:"none", width:"100%" },
  label:    { fontSize:10, letterSpacing:2, color:"#64748b", textTransform:"uppercase", marginBottom:5, display:"block", fontFamily:"'Orbitron',monospace" },
};

// ═══════════════════════════════════════════════════════════════
//  PRODUCT IMAGE COMPONENT
// ═══════════════════════════════════════════════════════════════
// mode="contain" → padded, shows full product cleanly (cards)
// mode="cover"   → fills container edge-to-edge (detail page, cart thumbs)
function ProductImage({ src, alt, emoji, style = {}, mode = "contain" }) {
  const [error, setError] = useState(false);

  if (!src || error) {
    return (
      <div className="img-fallback" style={style}>
        <span style={{ userSelect:"none", fontSize: mode === "cover" ? "4rem" : "3.5rem" }}>{emoji}</span>
      </div>
    );
  }

  return (
    <img
      className={mode === "cover" ? "product-img-cover" : "product-img"}
      src={src}
      alt={alt}
      onError={() => setError(true)}
      style={style}
    />
  );
}

// ═══════════════════════════════════════════════════════════════
//  REUSABLE COMPONENTS
// ═══════════════════════════════════════════════════════════════

// ── Toast ────────────────────────────────────────────────────
function Toast({ toast }) {
  if (!toast) return null;
  const colors = { success:"#00e5ff", error:"#ef4444", info:"#ff6b35" };
  const icons  = { success:"✓", error:"✕", info:"ℹ" };
  return (
    <div style={{ position:"fixed", bottom:22, right:22, zIndex:9999,
      background:"#0d1626", border:"1px solid #1a2640",
      borderLeft:`3px solid ${colors[toast.type]||colors.success}`,
      borderRadius:10, padding:"13px 18px",
      display:"flex", alignItems:"center", gap:9,
      fontSize:13, fontWeight:600, fontFamily:"'Rajdhani',sans-serif",
      boxShadow:"0 8px 32px rgba(0,0,0,.5)", maxWidth:300,
      animation:"slideIn .3s ease" }}>
      <span style={{color:colors[toast.type]||colors.success,fontSize:16}}>{icons[toast.type]||icons.success}</span>
      <span style={{color:"#e2e8f0"}}>{toast.msg}</span>
    </div>
  );
}

// ── Countdown ────────────────────────────────────────────────
function Countdown({ endTime }) {
  const [t, setT] = useState({h:0,m:0,s:0});
  useEffect(()=>{
    const tick=()=>{ const d=endTime-Date.now(); if(d<=0)return; setT({h:Math.floor(d/3600000)%24,m:Math.floor(d/60000)%60,s:Math.floor(d/1000)%60}); };
    tick(); const id=setInterval(tick,1000); return ()=>clearInterval(id);
  },[endTime]);
  return (
    <div style={{display:"flex",gap:8}}>
      {["H","M","S"].map((lbl,i)=>(
        <div key={lbl} style={{textAlign:"center",background:"#070b14",border:"1px solid #1a2640",borderRadius:8,padding:"7px 11px",minWidth:52}}>
          <span style={{...T.orbitron,fontSize:"1.3rem",fontWeight:700,color:"#00e5ff",display:"block"}}>{String([t.h,t.m,t.s][i]).padStart(2,"0")}</span>
          <span style={{fontSize:9,color:"#64748b",letterSpacing:1}}>{lbl}</span>
        </div>
      ))}
    </div>
  );
}

// ── ProductCard ──────────────────────────────────────────────
function ProductCard({ p, onNav, wishlist, onAddToCart, onToggleWish, inCart, animDelay=0 }) {
  const wished   = wishlist.some(i => i.id === p.id);
  const discount = p.orig ? Math.round((p.orig-p.price)/p.orig*100) : 0;
  const badgeBg  = p.badge && ["Sale","Best Seller"].includes(p.badge) ? "#ff6b35"
                 : p.badge ? "#a855f7" : "#00e5ff";

  return (
    <div className="fade-up" style={{...T.surface, display:"flex", flexDirection:"column", height:"100%", cursor:"pointer", transition:"all .3s", animationDelay:`${animDelay}ms`}}
      onMouseEnter={e=>{e.currentTarget.style.borderColor="#00e5ff";e.currentTarget.style.transform="translateY(-4px)";e.currentTarget.style.boxShadow="0 12px 40px rgba(0,229,255,.12)";}}
      onMouseLeave={e=>{e.currentTarget.style.borderColor="#1a2640";e.currentTarget.style.transform="";e.currentTarget.style.boxShadow="";}}>
      {/* Media */}
      <div style={{position:"relative",background:"#f8f9fa",height:190,display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",borderRadius:"12px 12px 0 0"}}
        onClick={()=>onNav("product",p.id)}>
        <ProductImage src={p.image1} alt={p.name} emoji={p.e} mode="contain" />
        {p.badge && <span style={{position:"absolute",top:10,left:10,background:badgeBg,color:"#fff",fontSize:9,fontWeight:700,letterSpacing:1,padding:"3px 9px",borderRadius:4,...T.orbitron,zIndex:2}}>{p.badge}</span>}
        {discount>0 && <span style={{position:"absolute",top:10,right:46,background:"#ff6b35",color:"#fff",fontSize:9,fontWeight:700,padding:"3px 7px",borderRadius:4,...T.orbitron,zIndex:2}}>-{discount}%</span>}
        <button onClick={e=>{e.stopPropagation();onToggleWish(p.id);}} style={{position:"absolute",top:10,right:10,background:"rgba(7,11,20,.8)",border:`1px solid ${wished?"#ec4899":"#1a2640"}`,color:wished?"#ec4899":"#64748b",width:34,height:34,borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",transition:"all .2s",fontSize:15,zIndex:2}}>{wished?"♥":"♡"}</button>
      </div>
      {/* Body */}
      <div style={{padding:14,flex:1,display:"flex",flexDirection:"column",gap:4}} onClick={()=>onNav("product",p.id)}>
        <div style={{fontSize:10,letterSpacing:2,...T.cyan,textTransform:"uppercase"}}>{p.cat}</div>
        <div style={{fontSize:13,fontWeight:700,color:"#e2e8f0",lineHeight:1.4}}>{p.name}</div>
        <div style={{fontSize:11,color:"#64748b",lineHeight:1.5,flex:1}}>{p.desc?.substring(0,70)}…</div>
        <div style={{display:"flex",alignItems:"center",gap:5,marginTop:4}}>
          <span style={{color:"#f59e0b",fontSize:11}}>{stars(p.rating)}</span>
          <span style={{fontWeight:600,fontSize:12}}>{p.rating}</span>
          <span style={{color:"#64748b",fontSize:11}}>({p.reviews?.toLocaleString()})</span>
        </div>
        <div style={{marginTop:4}}>
          <span style={{fontSize:"1.2rem",fontWeight:700,...T.cyan,...T.orbitron}}>${p.price}</span>
          {p.orig && <span style={{fontSize:12,color:"#64748b",textDecoration:"line-through",marginLeft:7}}>${p.orig}</span>}
        </div>
      </div>
      {/* Footer */}
      <div style={{padding:"10px 14px",borderTop:"1px solid #1a2640"}}>
        <button onClick={e=>{e.stopPropagation();onAddToCart(p.id);}}
          style={{width:"100%",background:inCart?"rgba(34,197,94,.12)":"transparent",border:`1px solid ${inCart?"#22c55e":"#1a2640"}`,color:inCart?"#22c55e":"#e2e8f0",padding:9,borderRadius:8,...T.rajdhani,fontWeight:600,cursor:"pointer",transition:"all .2s",display:"flex",alignItems:"center",justifyContent:"center",gap:7,fontSize:13}}
          onMouseEnter={e=>{if(!inCart){e.currentTarget.style.background="#00e5ff";e.currentTarget.style.borderColor="#00e5ff";e.currentTarget.style.color="#000";}}}
          onMouseLeave={e=>{if(!inCart){e.currentTarget.style.background="transparent";e.currentTarget.style.borderColor="#1a2640";e.currentTarget.style.color="#e2e8f0";}}}>
          {inCart?"✓ In Cart":"🛍 Add to Cart"}
        </button>
      </div>
    </div>
  );
}

// ── SectionHeader ────────────────────────────────────────────
function SectionHeader({ tag, title, onSeeAll }) {
  return (
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:32,flexWrap:"wrap",gap:12}}>
      <div>
        <span style={{fontSize:10,letterSpacing:4,...T.cyan,textTransform:"uppercase",display:"block",marginBottom:7}}>{tag}</span>
        <h2 style={{...T.orbitron,fontSize:"clamp(1.4rem,3vw,2rem)",fontWeight:700,color:"#fff"}}>{title}</h2>
        <div style={{width:56,height:2,background:"linear-gradient(90deg,#00e5ff,transparent)",marginTop:10}}/>
      </div>
      {onSeeAll && (
        <button onClick={onSeeAll} style={{background:"transparent",border:"1px solid #00e5ff",color:"#00e5ff",...T.orbitron,fontSize:10,fontWeight:700,letterSpacing:2,padding:"10px 20px",borderRadius:8,cursor:"pointer"}}>VIEW ALL →</button>
      )}
    </div>
  );
}

// ── PageBanner ───────────────────────────────────────────────
function PageBanner({ crumbs=[], title, sub, onNav }) {
  return (
    <div style={{padding:"52px 0 36px",position:"relative",borderBottom:"1px solid #1a2640"}}>
      <div style={{position:"absolute",inset:0,background:"linear-gradient(135deg,rgba(0,229,255,.03) 0%,transparent 50%)"}}/>
      <div className="container" style={{position:"relative",padding:"0 16px"}}>
        <div style={{display:"flex",gap:7,alignItems:"center",fontSize:12,...T.muted,marginBottom:16,flexWrap:"wrap"}}>
          {crumbs.map((c,i)=>(
            <span key={i} style={{display:"flex",alignItems:"center",gap:7}}>
              {c.nav ? <span style={{cursor:"pointer",transition:"color .2s"}} onMouseEnter={e=>e.target.style.color="#00e5ff"} onMouseLeave={e=>e.target.style.color="#64748b"} onClick={()=>onNav(c.nav)}>{c.label}</span> : <span style={{color:"#94a3b8"}}>{c.label}</span>}
              {i<crumbs.length-1 && <span style={{color:"#1a2640"}}>/</span>}
            </span>
          ))}
        </div>
        <h1 style={{...T.orbitron,fontSize:"clamp(1.4rem,4vw,2.3rem)",color:"#fff"}}>{title}</h1>
        {sub && <p style={{...T.muted,fontSize:13,marginTop:6}}>{sub}</p>}
      </div>
    </div>
  );
}

// ── Pagination ───────────────────────────────────────────────
function Pagination({ page, total, onChange }) {
  if (total<=1) return null;
  const pages=[];
  for(let i=1;i<=total;i++){
    const near=i===1||i===total||(i>=page-1&&i<=page+1);
    if(total>7){ if(Math.abs(i-page)===2) pages.push(<span key={`e${i}`} style={{padding:"7px 4px",fontSize:13,...T.muted}}>…</span>); else if(near) pages.push(<PgBtn key={i} n={i} cur={page} onChange={onChange}/>); }
    else pages.push(<PgBtn key={i} n={i} cur={page} onChange={onChange}/>);
  }
  return (
    <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:6,marginTop:40,flexWrap:"wrap"}}>
      <PgBtn n={page-1} cur={page} onChange={onChange} label="‹" disabled={page===1}/>
      {pages}
      <PgBtn n={page+1} cur={page} onChange={onChange} label="›" disabled={page===total}/>
    </div>
  );
}
function PgBtn({n,cur,onChange,label,disabled}) {
  return (
    <button onClick={()=>!disabled&&onChange(n)} disabled={disabled}
      style={{padding:"7px 13px",border:`1px solid ${n===cur?"#00e5ff":"#1a2640"}`,borderRadius:8,
        background:n===cur?"linear-gradient(135deg,#00e5ff,#0080ff)":"transparent",
        ...T.orbitron,fontSize:11,fontWeight:700,color:n===cur?"#000":"#64748b",
        cursor:disabled?"default":"pointer",opacity:disabled?.35:1,transition:"all .15s",minWidth:38,textAlign:"center"}}>
      {label||n}
    </button>
  );
}

