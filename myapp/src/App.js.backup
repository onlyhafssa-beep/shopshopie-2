            <h1 style={{...T.orbitron,fontSize:"clamp(2.2rem,5.5vw,4.2rem)",fontWeight:900,lineHeight:1.1,color:"#fff",marginBottom:20}}>
              EVERYTHING YOU<br/><span style={{color:"#00e5ff",textShadow:"0 0 30px rgba(0,229,255,.4)"}}>NEED & MORE</span>
            </h1>
            <p style={{color:"#94a3b8",fontSize:"1.05rem",lineHeight:1.7,marginBottom:32,...T.rajdhani,maxWidth:520}}>
              100+ premium products across Fashion, Electronics, Home, Beauty, Sports, Books, and more. Quality you can trust, prices you'll love.
            </p>
            <div style={{display:"flex",gap:12,flexWrap:"wrap"}}>
              <button onClick={()=>onNav("shop")} style={{...T.btnCyan}} onMouseEnter={e=>e.currentTarget.style.transform="translateY(-2px)"} onMouseLeave={e=>e.currentTarget.style.transform=""}>🛒 SHOP NOW</button>
              <button onClick={()=>onNav("deals")} style={{...T.btnGhost,borderColor:"#ff6b35",color:"#ff6b35"}} onMouseEnter={e=>{e.currentTarget.style.background="rgba(255,107,53,.1)";e.currentTarget.style.transform="translateY(-2px)";}} onMouseLeave={e=>{e.currentTarget.style.background="transparent";e.currentTarget.style.transform="";}}>⚡ VIEW DEALS</button>
            </div>
            <div style={{display:"flex",gap:32,marginTop:40,flexWrap:"wrap"}}>
              {[["100+","Products"],["10","Categories"],["50K+","Happy Customers"],["30-Day","Returns"]].map(([n,l])=>(
                <div key={l}><div style={{...T.orbitron,fontSize:"1.4rem",fontWeight:700,color:"#00e5ff"}}>{n}</div><div style={{fontSize:12,color:"#64748b",letterSpacing:1}}>{l}</div></div>
              ))}
            </div>
