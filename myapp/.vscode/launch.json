      height: 200px;
      background: radial-gradient(circle, rgba(0,245,255,0.15), transparent);
      border-radius: 50%;
    }

    /* Stats */
    .stat-box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
