          <span style={{ color: "var(--muted)", cursor: "default" }}>{product.name.toUpperCase().slice(0, 30)}...</span>
        </div>

        <div className="row g-5">
          <div className="col-12 col-md-5">
            <img src={product.img} alt={product.name} className="product-detail-img" style={{ width: "100%", borderRadius: 12 }} />
            <div className="d-flex gap-2 mt-3">
              {[1, 2, 3].map(i => (
                <img key={i} src={product.img} alt="" style={{ width: 70, height: 52, objectFit: "cover", borderRadius: 6, border: "1px solid var(--border)", cursor: "pointer" }} />
              ))}
            </div>
          </div>

          <div className="col-12 col-md-7">
            <div style={{ fontFamily: "Orbitron", fontSize: "0.6rem", letterSpacing: 3, color: "var(--purple)", marginBottom: 8 }}>
              {product.category.toUpperCase()}
            </div>
            <h1 style={{ fontFamily: "Rajdhani", fontWeight: 700, fontSize: "1.8rem", marginBottom: 16, lineHeight: 1.3 }}>
              {product.name}
            </h1>
            <div className="d-flex align-items-center gap-3 mb-4">
              <Stars rating={product.rating} />
              <span style={{ color: "var(--muted)", fontSize: "0.85rem" }}>{product.reviews} reviews</span>
            </div>

            <div style={{ fontFamily: "Orbitron", fontSize: "2rem", fontWeight: 700, background: "var(--gradient)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", marginBottom: 24 }}>
              ${product.price.toFixed(2)}
            </div>

            <p style={{ color: "var(--muted)", lineHeight: 1.8, marginBottom: 28 }}>
              Experience the pinnacle of performance with the {product.name}. Engineered for professionals
              and enthusiasts who demand nothing but the best. Every detail crafted for precision, comfort, and longevity.
            </p>

            <div className="d-flex align-items-center gap-3 mb-4 flex-wrap">
              <div className="qty-control">
                <button className="qty-btn" onClick={() => setQty(Math.max(1, qty - 1))}>−</button>
                <span style={{ fontFamily: "Orbitron", minWidth: 24, textAlign: "center" }}>{qty}</span>
                <button className="qty-btn" onClick={() => setQty(qty + 1)}>+</button>
              </div>
              <button className="btn-primary-cyber" style={{ flex: 1 }}
                onClick={() => { for (let i = 0; i < qty; i++) addToCart(product); }}>
                ADD TO CART
              </button>
              <button className="btn-wish" style={{ padding: "12px 16px", fontSize: "1.1rem" }}
                onClick={() => addToWishlist(product)}>♡</button>
            </div>

            <div style={{ display: "flex", gap: 16, marginBottom: 28, flexWrap: "wrap" }}>
              {["✓ Free Shipping", "✓ 2-Year Warranty", "✓ 30-Day Returns"].map(t => (
                <span key={t} style={{ color: "var(--cyan)", fontSize: "0.85rem", fontFamily: "Rajdhani" }}>{t}</span>
              ))}
            </div>

            <div>
              <div className="filter-title">SPECIFICATIONS</div>
              {Object.entries(specs).map(([k, v]) => (
                <div key={k} className="spec-row">
                  <span className="spec-key">{k}</span>
                  <span className="spec-val">{v}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        {related.length > 0 && (
          <div className="mt-5">
            <div className="cyber-divider" />
            <div className="section-header">
              <div className="section-tag">⬡ YOU MAY ALSO LIKE</div>
              <h2 className="section-title" style={{ fontSize: "1.8rem" }}>RELATED PRODUCTS</h2>
            </div>
            <div className="row g-4">
              {related.map(p => (
                <div key={p.id} className="col-6 col-md-3">
                  <ProductCard product={p} setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
};

// ─── SEARCH PAGE ──────────────────────────────────────────────────────────────
const SearchPage = ({ query, setPage, addToCart, addToWishlist }) => {
  const results = PRODUCTS.filter(p =>
    p.name.toLowerCase().includes(query.toLowerCase()) ||
    p.category.toLowerCase().includes(query.toLowerCase())
  );
  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">SEARCH RESULTS</h1>
        <p className="page-hero-sub">"{query}" — {results.length} results found</p>
      </div>
      <div className="container py-5">
        <div className="row g-4">
          {results.length === 0
            ? <div className="text-center py-5"><p style={{ color: "var(--muted)" }}>No results for "{query}"</p></div>
            : results.map(p => (
              <div key={p.id} className="col-12 col-sm-6 col-lg-3">
                <ProductCard product={p} setPage={setPage} addToCart={addToCart} addToWishlist={addToWishlist} />
              </div>
            ))}
        </div>
      </div>
    </div>
  );
};

// ─── DEALS PAGE ───────────────────────────────────────────────────────────────
const DealsPage = ({ setPage, addToCart }) => {
  const [time, setTime] = useState({ h: 5, m: 42, s: 17 });

  useEffect(() => {
    const t = setInterval(() => {
      setTime(prev => {
        let { h, m, s } = prev;
        s--; if (s < 0) { s = 59; m--; } if (m < 0) { m = 59; h--; } if (h < 0) { h = 0; m = 0; s = 0; }
        return { h, m, s };
      });
    }, 1000);
    return () => clearInterval(t);
  }, []);

  const deals = PRODUCTS.filter(p => p.badge === "SALE" || p.badge === "BESTSELLER" || p.badge === "HOT");

  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">⚡ DEALS & OFFERS</h1>
        <p className="page-hero-sub">Flash sales, limited time offers, and mega discounts</p>
      </div>
      <div className="container py-5">
        {/* Flash Sale Banner */}
        <div style={{
          background: "linear-gradient(135deg, rgba(0,245,255,0.1), rgba(191,0,255,0.1))",
          border: "1px solid var(--cyan)",
          borderRadius: 12,
          padding: 32,
          textAlign: "center",
          marginBottom: 48
        }}>
          <div className="section-tag">⚡ FLASH SALE ENDS IN</div>
          <div className="countdown" style={{ justifyContent: "center" }}>
            {[["h", "HOURS"], ["m", "MINS"], ["s", "SECS"]].map(([k, l]) => (
              <div key={k} className="countdown-unit">
                <span className="countdown-num">{String(time[k]).padStart(2, "0")}</span>
                <span className="countdown-label">{l}</span>
              </div>
            ))}
          </div>
          <h2 style={{ fontFamily: "Orbitron", fontSize: "2rem", background: "var(--gradient)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>
            UP TO 40% OFF
          </h2>
        </div>

        <div className="row g-4">
          {deals.map(p => (
            <div key={p.id} className="col-12 col-sm-6 col-md-4">
              <div className="deal-card" onClick={() => setPage({ name: "product", id: p.id })}>
                <div className="deal-badge">-25% OFF</div>
                <div style={{ padding: 20 }}>
                  <img src={p.img} alt={p.name} style={{ width: "100%", borderRadius: 8, marginBottom: 16 }} />
                  <div className="product-name">{p.name}</div>
                  <div className="d-flex align-items-center gap-2 mt-2">
                    <span className="product-price">${(p.price * 0.75).toFixed(2)}</span>
                    <span style={{ color: "var(--muted)", textDecoration: "line-through", fontSize: "0.85rem" }}>${p.price.toFixed(2)}</span>
                  </div>
                  <button className="btn-cart" style={{ width: "100%", marginTop: 12 }}
                    onClick={(e) => { e.stopPropagation(); addToCart(p); }}>
                    ADD TO CART
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

// ─── CART PAGE ────────────────────────────────────────────────────────────────
const CartPage = ({ cart, setCart, setPage }) => {
  const updateQty = (id, delta) => setCart(c => c.map(i => i.id === id ? { ...i, qty: Math.max(1, i.qty + delta) } : i));
  const removeItem = (id) => setCart(c => c.filter(i => i.id !== id));
  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  const shipping = subtotal > 100 ? 0 : 9.99;
  const total = subtotal + shipping;

  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">⬡ YOUR CART</h1>
        <p className="page-hero-sub">{cart.length} item{cart.length !== 1 ? "s" : ""} in your cart</p>
      </div>
      <div className="container py-5">
        {cart.length === 0 ? (
          <div className="text-center py-5">
            <div style={{ fontSize: "4rem", marginBottom: 16 }}>🛒</div>
            <h3 style={{ fontFamily: "Orbitron", color: "var(--cyan)", marginBottom: 12 }}>CART IS EMPTY</h3>
            <button className="btn-primary-cyber" onClick={() => setPage({ name: "shop" })}>START SHOPPING</button>
          </div>
        ) : (
          <div className="row g-4">
            <div className="col-12 col-lg-8">
              {cart.map(item => (
                <div key={item.id} className="cart-item">
                  <img src={item.img} alt={item.name} className="cart-item-img" />
                  <div style={{ flex: 1 }}>
                    <div style={{ fontWeight: 600, marginBottom: 4 }}>{item.name}</div>
                    <div style={{ color: "var(--muted)", fontSize: "0.8rem" }}>{item.category}</div>
                  </div>
                  <div className="qty-control">
                    <button className="qty-btn" onClick={() => updateQty(item.id, -1)}>−</button>
                    <span style={{ fontFamily: "Orbitron" }}>{item.qty}</span>
                    <button className="qty-btn" onClick={() => updateQty(item.id, 1)}>+</button>
                  </div>
                  <div style={{ fontFamily: "Orbitron", fontWeight: 700, color: "var(--cyan)", minWidth: 80, textAlign: "right" }}>
                    ${(item.price * item.qty).toFixed(2)}
                  </div>
                  <button onClick={() => removeItem(item.id)} style={{ background: "none", border: "none", color: "var(--muted)", cursor: "pointer", fontSize: "1.2rem" }}>×</button>
                </div>
              ))}
            </div>
            <div className="col-12 col-lg-4">
              <div className="order-summary-box">
                <div className="filter-title">ORDER SUMMARY</div>
                <div className="summary-row"><span>Subtotal</span><span>${subtotal.toFixed(2)}</span></div>
                <div className="summary-row"><span>Shipping</span><span>{shipping === 0 ? <span style={{ color: "var(--cyan)" }}>FREE</span> : `$${shipping.toFixed(2)}`}</span></div>
                <div className="summary-row"><span>Tax (8%)</span><span>${(subtotal * 0.08).toFixed(2)}</span></div>
                <div className="summary-total">
                  <span>TOTAL</span>
                  <span>${(total + total * 0.08).toFixed(2)}</span>
                </div>
                {subtotal > 0 && subtotal < 100 && (
                  <div style={{ color: "var(--cyan)", fontSize: "0.8rem", marginTop: 12 }}>
                    Add ${(100 - subtotal).toFixed(2)} more for FREE shipping!
                  </div>
                )}
                <button className="btn-primary-cyber" style={{ width: "100%", marginTop: 20 }}
                  onClick={() => setPage({ name: "checkout" })}>
                  PROCEED TO CHECKOUT
                </button>
                <button className="btn-outline-cyber" style={{ width: "100%", marginTop: 10 }}
                  onClick={() => setPage({ name: "shop" })}>
                  CONTINUE SHOPPING
                </button>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
};

// ─── CHECKOUT PAGE ────────────────────────────────────────────────────────────
const CheckoutPage = ({ cart, setCart, setPage, user, showToast }) => {
  const [step, setStep] = useState(1);
  const [loading, setLoading] = useState(false);
  const [form, setForm] = useState({
    firstName: "", lastName: "", email: user?.email || "", phone: "",
    address: "", city: "", state: "", zip: "", country: "US",
    cardNumber: "", cardName: "", expiry: "", cvv: "", coupon: ""
  });

  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  const total = (subtotal * 1.08 + (subtotal < 100 ? 9.99 : 0)).toFixed(2);

  const handleChange = (e) => setForm(f => ({ ...f, [e.target.name]: e.target.value }));

  const placeOrder = async () => {
    setLoading(true);
    try {
      const order = {
        userId: user?.uid || "guest",
        email: form.email,
        items: cart.map(i => ({ id: i.id, name: i.name, qty: i.qty, price: i.price })),
        total: parseFloat(total),
        shipping: { firstName: form.firstName, lastName: form.lastName, address: form.address, city: form.city, state: form.state, zip: form.zip, country: form.country },
        payment: { last4: form.cardNumber.slice(-4), status: "approved" },
        status: "processing",
        createdAt: serverTimestamp(),
      };
      const ref = await addDoc(collection(db, "orders"), order);
      setCart([]);
      setPage({ name: "confirmation", orderId: ref.id });
    } catch (err) {
      showToast("Error placing order. Please try again.");
    }
    setLoading(false);
  };

  const Field = ({ label, name, placeholder, type = "text", half }) => (
    <div className={`cyber-form-group ${half ? "col-6" : "col-12"}`}>
      <label className="cyber-label">{label}</label>
      <input type={type} name={name} className="cyber-input" placeholder={placeholder}
        value={form[name]} onChange={handleChange} />
    </div>
  );

  return (
    <div className="page-fade">
      <div className="page-hero">
        <h1 className="page-hero-title">⬡ CHECKOUT</h1>
        <div className="d-flex justify-content-center gap-4 mt-3">
          {["SHIPPING", "PAYMENT", "REVIEW"].map((s, i) => (
            <span key={s} style={{
              fontFamily: "Orbitron", fontSize: "0.65rem", letterSpacing: 2,
              color: step > i + 1 ? "var(--cyan)" : step === i + 1 ? "#fff" : "var(--muted)",
              borderBottom: step === i + 1 ? "2px solid var(--cyan)" : "none",
              paddingBottom: 4
            }}>
              {i + 1}. {s}
            </span>
          ))}
        </div>
      </div>
      <div className="container py-5">
        <div className="row g-4">
          <div className="col-12 col-lg-7">
            <div className="auth-card" style={{ maxWidth: "100%" }}>

              {step === 1 && (
                <div>
                  <div className="filter-title">SHIPPING INFORMATION</div>
                  <div className="row g-0">
                    <Field label="FIRST NAME" name="firstName" placeholder="John" half />
                    <div style={{ width: 12 }} />
                    <Field label="LAST NAME" name="lastName" placeholder="Doe" half />
                  </div>
                  <div className="row">
                    <Field label="EMAIL" name="email" placeholder="john@email.com" type="email" />
                    <Field label="PHONE" name="phone" placeholder="+1 555 0000" />
                    <Field label="ADDRESS" name="address" placeholder="123 Cyber Street" />
                    <Field label="CITY" name="city" placeholder="New York" half />
                    <Field label="STATE" name="state" placeholder="NY" half />
                    <Field label="ZIP CODE" name="zip" placeholder="10001" half />
                  </div>
                  <button className="btn-primary-cyber" style={{ width: "100%", marginTop: 8 }}
                    onClick={() => setStep(2)}>
                    CONTINUE TO PAYMENT
                  </button>
                </div>
              )}

              {step === 2 && (
                <div>
                  <div className="filter-title">PAYMENT DETAILS</div>
                  <div className="payment-card-preview">
                    <div style={{ fontFamily: "Orbitron", fontSize: "0.6rem", letterSpacing: 3, color: "var(--cyan)", marginBottom: 20 }}>
                      SHOPSHOPIE SECURE PAYMENT
                    </div>
                    <div style={{ letterSpacing: 4, fontSize: "1.1rem", marginBottom: 16, fontFamily: "Orbitron" }}>
                      {form.cardNumber ? form.cardNumber.replace(/(\d{4})/g, "$1 ").trim() : "**** **** **** ****"}
                    </div>
                    <div className="d-flex justify-content-between">
                      <span style={{ fontSize: "0.8rem", color: "var(--muted)" }}>{form.cardName || "CARD HOLDER"}</span>
                      <span style={{ fontSize: "0.8rem", color: "var(--muted)" }}>{form.expiry || "MM/YY"}</span>
                    </div>
                  </div>
                  <div className="cyber-alert" style={{ fontSize: "0.8rem" }}>
                    🔒 This is a DEMO payment gateway. No real charges will be made.
                  </div>
                  <Field label="CARD NUMBER" name="cardNumber" placeholder="4242 4242 4242 4242" />
                  <Field label="CARD HOLDER NAME" name="cardName" placeholder="John Doe" />
                  <div className="row">
                    <Field label="EXPIRY DATE" name="expiry" placeholder="MM/YY" half />
                    <Field label="CVV" name="cvv" placeholder="123" half />
                  </div>
                  <Field label="COUPON CODE (OPTIONAL)" name="coupon" placeholder="CYBER20" />
                  <div className="d-flex gap-3">
                    <button className="btn-outline-cyber" style={{ flex: 1 }} onClick={() => setStep(1)}>BACK</button>
                    <button className="btn-primary-cyber" style={{ flex: 1 }} onClick={() => setStep(3)}>REVIEW ORDER</button>
                  </div>
                </div>
              )}

              {step === 3 && (
                <div>
                  <div className="filter-title">REVIEW ORDER</div>
                  <div style={{ marginBottom: 24 }}>
                    {cart.map(item => (
                      <div key={item.id} className="d-flex justify-content-between align-items-center mb-3">
                        <div className="d-flex align-items-center gap-3">
                          <img src={item.img} alt="" style={{ width: 50, height: 38, objectFit: "cover", borderRadius: 6 }} />
                          <div>
                            <div style={{ fontSize: "0.85rem", fontWeight: 600 }}>{item.name}</div>
                            <div style={{ color: "var(--muted)", fontSize: "0.75rem" }}>Qty: {item.qty}</div>
                          </div>
                        </div>
                        <span style={{ fontFamily: "Orbitron", color: "var(--cyan)", fontSize: "0.9rem" }}>
                          ${(item.price * item.qty).toFixed(2)}
                        </span>
                      </div>
                    ))}
                  </div>
                  <div className="cyber-divider" style={{ margin: "16px 0" }} />
                  <div className="summary-total" style={{ marginBottom: 16 }}>
                    <span>TOTAL AMOUNT</span><span>${total}</span>
                  </div>
                  <div className="d-flex gap-3">
                    <button className="btn-outline-cyber" style={{ flex: 1 }} onClick={() => setStep(2)}>BACK</button>
                    <button className="btn-primary-cyber" style={{ flex: 1 }} onClick={placeOrder} disabled={loading}>
                      {loading ? "PROCESSING..." : "PLACE ORDER"}
                    </button>
                  </div>
                </div>
              )}
            </div>
          </div>

          <div className="col-12 col-lg-5">
            <div className="order-summary-box">
              <div className="filter-title">ORDER SUMMARY</div>
              {cart.map(item => (
                <div key={item.id} className="summary-row">
                  <span>{item.name.slice(0, 22)}... ×{item.qty}</span>
                  <span>${(item.price * item.qty).toFixed(2)}</span>
                </div>
              ))}
              <div className="cyber-divider" style={{ margin: "16px 0" }} />
              <div className="summary-total"><span>TOTAL</span><span>${total}</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

// ─── ORDER CONFIRMATION ───────────────────────────────────────────────────────
const ConfirmationPage = ({ orderId, setPage }) => (
  <div className="page-fade">
    <div className="container py-5 text-center" style={{ maxWidth: 600 }}>
      <div style={{ fontSize: "5rem", marginBottom: 20 }}>✦</div>
      <div className="section-tag">ORDER CONFIRMED</div>
      <h1 className="page-hero-title" style={{ marginBottom: 16 }}>THANK YOU!</h1>
      <p style={{ color: "var(--muted)", lineHeight: 1.8, marginBottom: 24 }}>
        Your order has been placed successfully. You'll receive a confirmation email shortly.
      </p>
      <div className="cyber-alert" style={{ textAlign: "left" }}>
        <div style={{ fontFamily: "Orbitron", fontSize: "0.6rem", letterSpacing: 2, marginBottom: 8 }}>ORDER ID</div>
        <code style={{ fontSize: "0.8rem" }}>{orderId}</code>
      </div>
      <div className="d-flex gap-3 justify-content-center mt-4">
        <button className="btn-primary-cyber" onClick={() => setPage({ name: "account" })}>VIEW ORDERS</button>
        <button className="btn-outline-cyber" onClick={() => setPage({ name: "home" })}>BACK HOME</button>
      </div>
